{% comment %}
  Section: TPA Hero (screenshot-matched)
  Keeps theme background by default. Optional custom gradient is available.
{% endcomment %}

<section
  class="tpa-hero tpa-hero--{{ section.id }} color-{{ section.settings.color_scheme }}"
  style="
    --tpa-accent: {{ section.settings.accent_color }};
    --tpa-cta: {{ section.settings.cta_color }};
    --tpa-cta-text: {{ section.settings.cta_text_color }};
    --tpa-secondary-text: {{ section.settings.secondary_text_color }};
    --tpa-border: rgba(255,255,255,0.10);
    {% if section.settings.use_custom_background %}
      --tpa-bg: linear-gradient({{ section.settings.bg_gradient_angle }}deg, {{ section.settings.bg_color_1 }}, {{ section.settings.bg_color_2 }});
    {% endif %}
  "
>
  <div class="tpa-hero__bg" aria-hidden="true"></div>
  <div class="tpa-hero__orb" aria-hidden="true"></div>

  <div class="tpa-hero__inner {% if section.settings.section_width == 'full-width' %}tpa-hero__inner--full{% endif %}">
    <div class="tpa-hero__content">
      {% if section.settings.eyebrow != blank %}
        <div class="tpa-hero__eyebrow tpa-reveal" data-tpa-reveal>
          <span class="tpa-hero__eyebrow-dot" aria-hidden="true"></span>
          {{ section.settings.eyebrow }}
        </div>
      {% endif %}

      <h1 class="tpa-hero__title tpa-reveal" data-tpa-reveal data-delay="1">
        <span class="tpa-hero__title-line">{{ section.settings.headline_line_1 }}</span>
        <span class="tpa-hero__title-line">
          <span class="tpa-hero__title-accent">{{ section.settings.headline_accent }}</span>
        </span>
      </h1>

      {% if section.settings.subcopy != blank %}
        <p class="tpa-hero__subcopy tpa-reveal" data-tpa-reveal data-delay="2">{{ section.settings.subcopy }}</p>
      {% endif %}

      <div class="tpa-hero__actions tpa-reveal" data-tpa-reveal data-delay="3">
        {% if section.settings.primary_label != blank and section.settings.primary_link != blank %}
          <a class="tpa-hero__btn tpa-hero__btn--primary" href="{{ section.settings.primary_link }}">
            <span class="tpa-hero__btn-shimmer" aria-hidden="true"></span>
            {{ section.settings.primary_label }}
            <span class="tpa-hero__arrow" aria-hidden="true">→</span>
          </a>
        {% endif %}

        {% if section.settings.secondary_label != blank and section.settings.secondary_link != blank %}
          <a class="tpa-hero__btn tpa-hero__btn--secondary" href="{{ section.settings.secondary_link }}">
            {{ section.settings.secondary_label }}
          </a>
        {% endif %}
      </div>
    </div>

    <div class="tpa-hero__trust tpa-reveal" data-tpa-reveal data-delay="4">
      {% if section.settings.trust_1 != blank %}
        <div class="tpa-hero__trust-item" data-tpa-trust-item>
          <span class="tpa-hero__check" aria-hidden="true">✓</span>
          <span>{{ section.settings.trust_1 }}</span>
        </div>
      {% endif %}
      {% if section.settings.trust_2 != blank %}
        <div class="tpa-hero__trust-item" data-tpa-trust-item>
          <span class="tpa-hero__check" aria-hidden="true">✓</span>
          <span>{{ section.settings.trust_2 }}</span>
        </div>
      {% endif %}
      {% if section.settings.trust_3 != blank %}
        <div class="tpa-hero__trust-item" data-tpa-trust-item>
          <span class="tpa-hero__check" aria-hidden="true">✓</span>
          <span>{{ section.settings.trust_3 }}</span>
        </div>
      {% endif %}
      {% if section.settings.trust_4 != blank %}
        <div class="tpa-hero__trust-item" data-tpa-trust-item>
          <span class="tpa-hero__check" aria-hidden="true">✓</span>
          <span>{{ section.settings.trust_4 }}</span>
        </div>
      {% endif %}
    </div>
  </div>
</section>

<style>
  .tpa-hero--{{ section.id }} {
    position: relative;
    overflow: hidden;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    color: #fff;
  }
  .tpa-hero--{{ section.id }}{
  background: radial-gradient(1200px 700px at 20% 20%, rgba(29,91,255,0.35), rgba(0,0,0,0) 60%),
              linear-gradient(135deg, #06122C, #071A3A);
  }

  /* Subtle dotted texture like the screenshot (does not replace the gradient). */
  .tpa-hero--{{ section.id }} .tpa-hero__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      radial-gradient(circle at 1px 1px, rgba(255,255,255,0.08) 1px, rgba(0,0,0,0) 1.6px);
    background-size: 22px 22px;
    opacity: 0.35;
    mix-blend-mode: screen;
  }

  .tpa-hero--{{ section.id }} .tpa-hero__inner {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    padding: 88px 24px 26px;
  }

  .tpa-hero--{{ section.id }} .tpa-hero__inner--full {
    max-width: none;
    padding-left: 32px;
    padding-right: 32px;
  }

  .tpa-hero--{{ section.id }} .tpa-hero__content {
    max-width: 860px;
  }

  .tpa-hero--{{ section.id }} .tpa-hero__eyebrow {
    display: inline-flex;
    align-items: center;
    padding: 10px 16px;
    border-radius: 999px;
    background: rgba(0,0,0,0.20);
    border: 1px solid rgba(255,255,255,0.10);
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    font-size: 13px;
  }

  .tpa-hero--{{ section.id }} .tpa-hero__title {
    margin: 18px 0 0;
    line-height: 0.98;
    font-weight: 800;
    letter-spacing: -0.03em;
    font-size: clamp(44px, 6.2vw, 92px);
  }

  .tpa-hero--{{ section.id }} .tpa-hero__title-line {
    display: block;
  }

  .tpa-hero--{{ section.id }} .tpa-hero__title-accent {
    color: var(--tpa-accent);
  }

  .tpa-hero--{{ section.id }} .tpa-hero__subcopy {
    margin: 16px 0 0;
    max-width: 760px;
    color: rgba(255,255,255,0.72);
    font-size: 22px;
    line-height: 1.45;
  }

  .tpa-hero--{{ section.id }} .tpa-hero__actions {
    margin-top: 34px;
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .tpa-hero--{{ section.id }} .tpa-hero__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    height: 62px;
    padding: 0 26px;
    border-radius: 18px;
    font-weight: 800;
    font-size: 18px;
    text-decoration: none;
    transition: transform 160ms ease, background-color 160ms ease, border-color 160ms ease, opacity 160ms ease;
    will-change: transform;
  }

  .tpa-hero--{{ section.id }} .tpa-hero__btn:active {
    transform: translateY(1px);
  }

  .tpa-hero--{{ section.id }} .tpa-hero__btn--primary {
    background: var(--tpa-cta);
    color: var(--tpa-cta-text);
    border: 1px solid rgba(255,255,255,0.08);
    box-shadow: 0 12px 30px rgba(0,0,0,0.28);
    min-width: 260px;
  }

  .tpa-hero--{{ section.id }} .tpa-hero__btn--primary:hover {
    opacity: 0.95;
  }

  .tpa-hero--{{ section.id }} .tpa-hero__btn--secondary {
    background: rgba(0,0,0,0.18);
    color: var(--tpa-secondary-text);
    border: 1px solid rgba(255,255,255,0.12);
    min-width: 220px;
  }

  .tpa-hero--{{ section.id }} .tpa-hero__btn--secondary:hover {
    border-color: rgba(255,255,255,0.20);
  }

  .tpa-hero--{{ section.id }} .tpa-hero__arrow {
    font-size: 20px;
    line-height: 1;
  }

  .tpa-hero--{{ section.id }} .tpa-hero__trust {
    margin-top: 58px;
    padding-top: 18px;
    border-top: 1px solid rgba(255,255,255,0.10);
    display: flex;
    gap: 28px;
    flex-wrap: wrap;
    align-items: center;
    color: rgba(255,255,255,0.82);
    font-weight: 700;
  }

  .tpa-hero--{{ section.id }} .tpa-hero__trust-item {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-size: 18px;
    white-space: nowrap;
  }

  .tpa-hero--{{ section.id }} .tpa-hero__check {
    width: 28px;
    height: 28px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(22, 163, 74, 0.18);
    border: 1px solid rgba(34, 197, 94, 0.35);
    color: rgba(187, 247, 208, 0.95);
    font-weight: 900;
  }

  /* --- Floating gradient orb --- */
  .tpa-hero--{{ section.id }} .tpa-hero__orb{
    position: absolute;
    top: -120px;
    right: -80px;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(29,91,255,0.18) 0%, rgba(29,91,255,0) 70%);
    animation: tpaOrbFloat{{ section.id }} 8s ease-in-out infinite alternate;
    pointer-events: none;
    will-change: transform;
  }

  @keyframes tpaOrbFloat{{ section.id }}{
    0%{ transform: translate(0, 0) scale(1); }
    100%{ transform: translate(-40px, 30px) scale(1.08); }
  }

  /* --- Eyebrow live dot --- */
  .tpa-hero--{{ section.id }} .tpa-hero__eyebrow-dot{
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: rgba(34, 197, 94, 0.95);
    box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.5);
    animation: tpaEyebrowPulse{{ section.id }} 2s ease-in-out infinite;
    display: inline-block;
    margin-right: 8px;
    vertical-align: middle;
  }
  @keyframes tpaEyebrowPulse{{ section.id }}{
    0%, 100%{ box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.5); }
    50%{ box-shadow: 0 0 0 6px rgba(34, 197, 94, 0); }
  }

  /* --- CTA shimmer effect --- */
  .tpa-hero--{{ section.id }} .tpa-hero__btn--primary{
    position: relative;
    overflow: hidden;
  }
  .tpa-hero--{{ section.id }} .tpa-hero__btn-shimmer{
    position: absolute;
    top: 0;
    left: -100%;
    width: 60%;
    height: 100%;
    background: linear-gradient(90deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.15) 50%, rgba(255,255,255,0) 100%);
    animation: tpaShimmer{{ section.id }} 3s ease-in-out infinite;
    pointer-events: none;
  }
  @keyframes tpaShimmer{{ section.id }}{
    0%{ left: -100%; }
    50%{ left: 150%; }
    100%{ left: 150%; }
  }

  .tpa-hero--{{ section.id }} .tpa-hero__btn--primary:hover{
    opacity: 1;
    transform: translateY(-2px);
    box-shadow: 0 16px 40px rgba(29,91,255,0.35), 0 0 0 1px rgba(29,91,255,0.2);
  }

  .tpa-hero--{{ section.id }} .tpa-hero__btn--secondary:hover{
    border-color: rgba(255,255,255,0.25);
    background: rgba(255,255,255,0.06);
    transform: translateY(-1px);
  }

  /* --- Entrance reveal animations --- */
  .tpa-hero--{{ section.id }} .tpa-reveal{
    opacity: 0;
    transform: translateY(24px);
    animation: tpaRevealUp{{ section.id }} 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .tpa-hero--{{ section.id }} .tpa-reveal[data-delay="1"]{ animation-delay: 0.12s; }
  .tpa-hero--{{ section.id }} .tpa-reveal[data-delay="2"]{ animation-delay: 0.24s; }
  .tpa-hero--{{ section.id }} .tpa-reveal[data-delay="3"]{ animation-delay: 0.36s; }
  .tpa-hero--{{ section.id }} .tpa-reveal[data-delay="4"]{ animation-delay: 0.5s; }

  @keyframes tpaRevealUp{{ section.id }}{
    to{ opacity: 1; transform: translateY(0); }
  }

  /* --- Trust item stagger on hover --- */
  .tpa-hero--{{ section.id }} .tpa-hero__trust-item{
    transition: transform 200ms ease, color 200ms ease;
  }
  .tpa-hero--{{ section.id }} .tpa-hero__trust-item:hover{
    transform: translateY(-2px);
    color: rgba(255,255,255,0.98);
  }
  .tpa-hero--{{ section.id }} .tpa-hero__check{
    transition: transform 200ms ease, background 200ms ease;
  }
  .tpa-hero--{{ section.id }} .tpa-hero__trust-item:hover .tpa-hero__check{
    transform: scale(1.12);
    background: rgba(22, 163, 74, 0.28);
  }

  /* --- Arrow bounce on button hover --- */
  .tpa-hero--{{ section.id }} .tpa-hero__btn--primary:hover .tpa-hero__arrow{
    animation: tpaArrowBounce{{ section.id }} 0.6s ease infinite;
  }
  @keyframes tpaArrowBounce{{ section.id }}{
    0%, 100%{ transform: translateX(0); }
    50%{ transform: translateX(4px); }
  }

  @media (max-width: 860px) {
    .tpa-hero--{{ section.id }} .tpa-hero__inner {
      padding-top: 58px;
    }
    .tpa-hero--{{ section.id }} .tpa-hero__subcopy {
      font-size: 18px;
    }
    .tpa-hero--{{ section.id }} .tpa-hero__btn {
      width: 100%;
      min-width: 0;
    }
    .tpa-hero--{{ section.id }} .tpa-hero__trust-item {
      font-size: 16px;
    }
    .tpa-hero--{{ section.id }} .tpa-hero__orb{
      width: 350px;
      height: 350px;
      top: -60px;
      right: -60px;
    }
  }

  @media (prefers-reduced-motion: reduce){
    .tpa-hero--{{ section.id }} .tpa-reveal{
      opacity: 1;
      transform: none;
      animation: none;
    }
    .tpa-hero--{{ section.id }} .tpa-hero__btn-shimmer,
    .tpa-hero--{{ section.id }} .tpa-hero__orb{
      animation: none;
    }
    .tpa-hero--{{ section.id }} .tpa-hero__eyebrow-dot{
      animation: none;
    }
  }
</style>

{% schema %}
{
  "name": "TPA Hero",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Copy"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow pill",
      "default": "AUSTRALIA'S TRUSTED PARTS SPECIALIST"
    },
    {
      "type": "text",
      "id": "headline_line_1",
      "label": "Headline line 1",
      "default": "Your Appliance Isn't Broken."
    },
    {
      "type": "text",
      "id": "headline_accent",
      "label": "Headline line 2 (accent)",
      "default": "It Just Needs the Right Part."
    },
    {
      "type": "textarea",
      "id": "subcopy",
      "label": "Subcopy",
      "default": "Guaranteed-fit replacement parts & accessories for Dyson, Ecovacs, Thermomix & Breville. Ships fast across Australia."
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary label",
      "default": "Find Your Part"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary label",
      "default": "View Best Sellers"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary link"
    },
    {
      "type": "header",
      "content": "Trust bar"
    },
    {
      "type": "text",
      "id": "trust_1",
      "label": "Trust item 1",
      "default": "Perfect Fit Guarantee"
    },
    {
      "type": "text",
      "id": "trust_2",
      "label": "Trust item 2",
      "default": "Fast AU Shipping"
    },
    {
      "type": "text",
      "id": "trust_3",
      "label": "Trust item 3",
      "default": "30-Day Returns"
    },
    {
      "type": "text",
      "id": "trust_4",
      "label": "Trust item 4",
      "default": "50,000+ Parts Sold"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent blue (headline line 2)",
      "default": "#1D5BFF"
    },
    {
      "type": "color",
      "id": "cta_color",
      "label": "Primary button background",
      "default": "#1D5BFF"
    },
    {
      "type": "color",
      "id": "cta_text_color",
      "label": "Primary button text",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "secondary_text_color",
      "label": "Secondary button text",
      "default": "#EAF1FF"
    },
    {
      "type": "header",
      "content": "Background (optional)"
    },
    {
      "type": "checkbox",
      "id": "use_custom_background",
      "label": "Use custom background gradient (leave off to keep theme background)",
      "default": false
    },
    {
      "type": "range",
      "id": "bg_gradient_angle",
      "label": "Gradient angle",
      "min": 0,
      "max": 360,
      "step": 5,
      "default": 135
    },
    {
      "type": "color",
      "id": "bg_color_1",
      "label": "Background color 1",
      "default": "#06122C"
    },
    {
      "type": "color",
      "id": "bg_color_2",
      "label": "Background color 2",
      "default": "#071A3A"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "TPA Hero"
    }
  ]
}
{% endschema %}