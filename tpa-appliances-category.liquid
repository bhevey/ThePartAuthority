{% comment %}
  Section: TPA Appliances Category Page
  Sub-category landing for Appliances – 7 cards with professional SVG icons,
  hero banner, scroll-triggered animations, and full mobile responsiveness.
{% endcomment %}

<section class="tpa-appliances tpa-appliances--{{ section.id }} color-{{ section.settings.color_scheme }}">

  {%- comment -%} ── Hero Banner ── {%- endcomment -%}
  <div class="tpa-appliances__hero">
    <div class="tpa-appliances__hero-bg" aria-hidden="true">
      <div class="tpa-appliances__hero-orb tpa-appliances__hero-orb--1"></div>
      <div class="tpa-appliances__hero-orb tpa-appliances__hero-orb--2"></div>
      <div class="tpa-appliances__hero-dots"></div>
    </div>
    <div class="tpa-appliances__hero-inner">
      <div class="tpa-appliances__hero-pill" data-tpa-app-reveal>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        {{ section.settings.pill_text }}
      </div>
      {% if section.settings.heading != blank %}
        <h1 class="tpa-appliances__hero-title" data-tpa-app-reveal>{{ section.settings.heading }}</h1>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="tpa-appliances__hero-desc" data-tpa-app-reveal>{{ section.settings.subheading }}</p>
      {% endif %}
    </div>
  </div>

  {%- comment -%} ── Category Grid ── {%- endcomment -%}
  <div class="tpa-appliances__body">
    <div class="tpa-appliances__inner {% if section.settings.section_width == 'full-width' %}tpa-appliances__inner--full{% endif %}">

      {% if section.settings.grid_heading != blank %}
        <h2 class="tpa-appliances__grid-heading" data-tpa-app-reveal>{{ section.settings.grid_heading }}</h2>
      {% endif %}

      <div class="tpa-appliances__grid" data-tpa-app-grid>
        {% for block in section.blocks %}
          <a
            class="tpa-app-card"
            href="{{ block.settings.link | default: routes.all_products_collection_url }}"
            {{ block.shopify_attributes }}
            style="--accent: {{ block.settings.accent | default: section.settings.accent_color }}; --card-idx: {{ forloop.index0 }};"
            data-tpa-app-card
          >
            {%- comment -%} Icon container with inline SVG ── {%- endcomment -%}
            <div class="tpa-app-card__icon-wrap">
              <div class="tpa-app-card__icon">
                {% if block.settings.icon_image != blank %}
                  <img
                    src="{{ block.settings.icon_image | image_url: width: 160 }}"
                    alt="{{ block.settings.title | escape }}"
                    loading="lazy"
                    width="44"
                    height="44"
                  >
                {% else %}
                  <span class="tpa-app-card__svg" aria-hidden="true">{{ block.settings.fallback_icon }}</span>
                {% endif %}
              </div>
              <div class="tpa-app-card__icon-glow" aria-hidden="true"></div>
            </div>

            {%- comment -%} Content ── {%- endcomment -%}
            <div class="tpa-app-card__body">
              <h3 class="tpa-app-card__title">{{ block.settings.title }}</h3>
              {% if block.settings.kicker != blank %}
                <div class="tpa-app-card__kicker">{{ block.settings.kicker }}</div>
              {% endif %}
              {% if block.settings.description != blank %}
                <p class="tpa-app-card__desc">{{ block.settings.description }}</p>
              {% endif %}
            </div>

            {%- comment -%} CTA ── {%- endcomment -%}
            <div class="tpa-app-card__cta">
              <span class="tpa-app-card__cta-label">{{ block.settings.cta_label }}</span>
              <span class="tpa-app-card__arrow" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </span>
            </div>
          </a>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{%- comment -%} ═══════════════════════════════ CSS ═══════════════════════════════ {%- endcomment -%}
<style>
  /* ── Root / Section ── */
  .tpa-appliances--{{ section.id }}{
    --tpa-accent: {{ section.settings.accent_color }};
  }

  /* ── Hero Banner ── */
  .tpa-appliances--{{ section.id }} .tpa-appliances__hero{
    position: relative;
    overflow: hidden;
    background: linear-gradient(165deg, #06122C 0%, #0A1E45 40%, #071A3A 100%);
    padding: clamp(56px, 8vw, 96px) 24px clamp(48px, 6vw, 80px);
    text-align: center;
  }

  .tpa-appliances--{{ section.id }} .tpa-appliances__hero-bg{
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .tpa-appliances--{{ section.id }} .tpa-appliances__hero-dots{
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.06) 1px, transparent 0);
    background-size: 28px 28px;
  }

  .tpa-appliances--{{ section.id }} .tpa-appliances__hero-orb{
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    animation: tpa-app-float 12s ease-in-out infinite alternate;
  }
  .tpa-appliances--{{ section.id }} .tpa-appliances__hero-orb--1{
    width: 500px;
    height: 500px;
    top: -120px;
    left: -80px;
    background: radial-gradient(circle, rgba(29, 91, 255, 0.30) 0%, transparent 70%);
  }
  .tpa-appliances--{{ section.id }} .tpa-appliances__hero-orb--2{
    width: 400px;
    height: 400px;
    bottom: -100px;
    right: -60px;
    background: radial-gradient(circle, rgba(99, 145, 255, 0.20) 0%, transparent 70%);
    animation-delay: -6s;
  }

  @keyframes tpa-app-float{
    0%{ transform: translate(0, 0) scale(1); }
    100%{ transform: translate(30px, -20px) scale(1.08); }
  }

  .tpa-appliances--{{ section.id }} .tpa-appliances__hero-inner{
    position: relative;
    z-index: 1;
    max-width: 780px;
    margin: 0 auto;
  }

  .tpa-appliances--{{ section.id }} .tpa-appliances__hero-pill{
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 18px;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,0.12);
    background: rgba(255,255,255,0.06);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: rgba(255,255,255,0.85);
    margin-bottom: 24px;
  }
  .tpa-appliances--{{ section.id }} .tpa-appliances__hero-pill svg{
    color: #5B9AFF;
  }

  .tpa-appliances--{{ section.id }} .tpa-appliances__hero-title{
    margin: 0;
    font-weight: 950;
    letter-spacing: -0.035em;
    line-height: 1.02;
    font-size: clamp(32px, 5vw, 54px);
    color: #FFFFFF;
  }

  .tpa-appliances--{{ section.id }} .tpa-appliances__hero-desc{
    margin: 16px auto 0;
    max-width: 560px;
    font-size: clamp(15px, 1.8vw, 18px);
    line-height: 1.55;
    color: rgba(255,255,255,0.65);
  }

  /* ── Body / Grid Area ── */
  .tpa-appliances--{{ section.id }} .tpa-appliances__body{
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  .tpa-appliances--{{ section.id }} .tpa-appliances__inner{
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .tpa-appliances--{{ section.id }} .tpa-appliances__inner--full{
    max-width: none;
    padding: 0 32px;
  }

  .tpa-appliances--{{ section.id }} .tpa-appliances__grid-heading{
    text-align: center;
    margin: 0 0 36px;
    font-weight: 900;
    font-size: clamp(22px, 2.8vw, 32px);
    letter-spacing: -0.02em;
    color: rgb(var(--color-foreground));
  }

  /* ── Grid Layout ── */
  .tpa-appliances--{{ section.id }} .tpa-appliances__grid{
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 22px;
    align-items: stretch;
  }

  /* Make the last row center when fewer than 3 items */
  .tpa-appliances--{{ section.id }} .tpa-appliances__grid .tpa-app-card:last-child:nth-child(3n+1){
    grid-column: 2;
  }

  /* ── Card ── */
  .tpa-appliances--{{ section.id }} .tpa-app-card{
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 30px 28px 22px;
    border-radius: 18px;
    text-decoration: none;
    border: 1px solid rgba(15, 23, 42, 0.10);
    background: rgba(255,255,255,0.95);
    box-shadow:
      0 1px 3px rgba(2, 6, 23, 0.04),
      0 8px 30px rgba(2, 6, 23, 0.07);
    transition: transform 220ms cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 220ms cubic-bezier(0.16, 1, 0.3, 1),
                border-color 220ms ease;
    cursor: pointer;
    min-height: 290px;
  }

  .tpa-appliances--{{ section.id }} .tpa-app-card:hover{
    transform: translateY(-6px);
    border-color: var(--accent);
    box-shadow:
      0 24px 60px rgba(2, 6, 23, 0.13),
      0 8px 22px rgba(2, 6, 23, 0.08),
      0 0 0 1px var(--accent);
  }

  .tpa-appliances--{{ section.id }} .tpa-app-card:focus-visible{
    outline: 3px solid rgba(29, 91, 255, 0.35);
    outline-offset: 3px;
  }

  /* ── Icon ── */
  .tpa-appliances--{{ section.id }} .tpa-app-card__icon-wrap{
    position: relative;
    width: 62px;
    height: 62px;
    flex-shrink: 0;
  }

  .tpa-appliances--{{ section.id }} .tpa-app-card__icon{
    position: relative;
    z-index: 1;
    width: 62px;
    height: 62px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(29, 91, 255, 0.08) 0%, rgba(29, 91, 255, 0.04) 100%);
    border: 1px solid rgba(29, 91, 255, 0.10);
    transition: transform 300ms cubic-bezier(0.16, 1, 0.3, 1),
                background 300ms ease,
                border-color 300ms ease,
                box-shadow 300ms ease;
  }

  .tpa-appliances--{{ section.id }} .tpa-app-card:hover .tpa-app-card__icon{
    transform: scale(1.08) rotate(-3deg);
    background: linear-gradient(135deg, rgba(29, 91, 255, 0.14) 0%, rgba(29, 91, 255, 0.06) 100%);
    border-color: rgba(29, 91, 255, 0.18);
    box-shadow: 0 8px 24px rgba(29, 91, 255, 0.15);
  }

  .tpa-appliances--{{ section.id }} .tpa-app-card__icon-glow{
    position: absolute;
    inset: -4px;
    border-radius: 20px;
    background: radial-gradient(circle, rgba(29, 91, 255, 0.12) 0%, transparent 70%);
    opacity: 0;
    transition: opacity 300ms ease;
  }
  .tpa-appliances--{{ section.id }} .tpa-app-card:hover .tpa-app-card__icon-glow{
    opacity: 1;
  }

  .tpa-appliances--{{ section.id }} .tpa-app-card__icon img{
    width: 32px;
    height: 32px;
    object-fit: contain;
    display: block;
  }

  .tpa-appliances--{{ section.id }} .tpa-app-card__svg{
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent, #1D5BFF);
  }
  .tpa-appliances--{{ section.id }} .tpa-app-card__svg svg{
    width: 28px;
    height: 28px;
    stroke-width: 1.8;
  }

  /* ── Card Body ── */
  .tpa-appliances--{{ section.id }} .tpa-app-card__body{
    margin-top: 18px;
    flex: 1;
  }

  .tpa-appliances--{{ section.id }} .tpa-app-card__title{
    margin: 0;
    font-size: 21px;
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: rgb(var(--color-foreground));
  }

  .tpa-appliances--{{ section.id }} .tpa-app-card__kicker{
    margin-top: 8px;
    font-size: 12.5px;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .tpa-appliances--{{ section.id }} .tpa-app-card__desc{
    margin: 10px 0 0;
    font-size: 14.5px;
    line-height: 1.55;
    color: rgba(var(--color-foreground), 0.65);
  }

  /* ── CTA ── */
  .tpa-appliances--{{ section.id }} .tpa-app-card__cta{
    margin-top: 18px;
    padding-top: 14px;
    border-top: 1px solid rgba(15, 23, 42, 0.08);
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    font-weight: 800;
    color: var(--accent);
  }

  .tpa-appliances--{{ section.id }} .tpa-app-card__cta-label{
    position: relative;
  }
  .tpa-appliances--{{ section.id }} .tpa-app-card__cta-label::after{
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--accent);
    border-radius: 999px;
    transition: width 250ms ease;
  }
  .tpa-appliances--{{ section.id }} .tpa-app-card:hover .tpa-app-card__cta-label::after{
    width: 100%;
  }

  .tpa-appliances--{{ section.id }} .tpa-app-card__arrow{
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 220ms ease;
  }
  .tpa-appliances--{{ section.id }} .tpa-app-card:hover .tpa-app-card__arrow{
    transform: translateX(4px);
  }

  /* ── Scroll-triggered entrance ── */
  .tpa-appliances--{{ section.id }} [data-tpa-app-reveal]{
    opacity: 0;
    transform: translateY(20px);
  }
  .tpa-appliances--{{ section.id }} [data-tpa-app-reveal].is-revealed{
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.55s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.55s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .tpa-appliances--{{ section.id }} .tpa-app-card{
    opacity: 0;
    transform: translateY(28px);
  }
  .tpa-appliances--{{ section.id }} .tpa-app-card.is-revealed{
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 220ms cubic-bezier(0.16, 1, 0.3, 1),
                border-color 220ms ease;
    transition-delay: calc(var(--card-idx, 0) * 0.09s);
  }
  .tpa-appliances--{{ section.id }} .tpa-app-card.is-revealed:hover{
    transition-delay: 0s;
  }

  /* ── Responsive: Tablet ── */
  @media (max-width: 980px){
    .tpa-appliances--{{ section.id }} .tpa-appliances__grid{
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px;
    }
    .tpa-appliances--{{ section.id }} .tpa-appliances__grid .tpa-app-card:last-child:nth-child(3n+1){
      grid-column: auto;
    }
    .tpa-appliances--{{ section.id }} .tpa-app-card{
      min-height: 260px;
    }
  }

  /* ── Responsive: Mobile ── */
  @media (max-width: 620px){
    .tpa-appliances--{{ section.id }} .tpa-appliances__hero{
      padding: 44px 20px 40px;
    }
    .tpa-appliances--{{ section.id }} .tpa-appliances__inner{
      padding: 0 16px;
    }
    .tpa-appliances--{{ section.id }} .tpa-appliances__grid{
      grid-template-columns: 1fr;
      gap: 14px;
    }
    .tpa-appliances--{{ section.id }} .tpa-app-card{
      padding: 22px 20px 18px;
      min-height: 0;
      flex-direction: row;
      flex-wrap: wrap;
      align-items: flex-start;
      gap: 0 16px;
    }
    .tpa-appliances--{{ section.id }} .tpa-app-card__icon-wrap{
      width: 52px;
      height: 52px;
    }
    .tpa-appliances--{{ section.id }} .tpa-app-card__icon{
      width: 52px;
      height: 52px;
      border-radius: 14px;
    }
    .tpa-appliances--{{ section.id }} .tpa-app-card__svg svg{
      width: 24px;
      height: 24px;
    }
    .tpa-appliances--{{ section.id }} .tpa-app-card__body{
      flex: 1;
      margin-top: 0;
      min-width: 0;
    }
    .tpa-appliances--{{ section.id }} .tpa-app-card__title{
      font-size: 18px;
    }
    .tpa-appliances--{{ section.id }} .tpa-app-card__desc{
      font-size: 13.5px;
    }
    .tpa-appliances--{{ section.id }} .tpa-app-card__cta{
      width: 100%;
      margin-top: 14px;
      padding-top: 12px;
    }
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce){
    .tpa-appliances--{{ section.id }} .tpa-app-card,
    .tpa-appliances--{{ section.id }} .tpa-app-card__icon,
    .tpa-appliances--{{ section.id }} .tpa-app-card__arrow,
    .tpa-appliances--{{ section.id }} [data-tpa-app-reveal]{
      transition: none !important;
      animation: none !important;
    }
    .tpa-appliances--{{ section.id }} .tpa-app-card,
    .tpa-appliances--{{ section.id }} [data-tpa-app-reveal]{
      opacity: 1;
      transform: none;
    }
    .tpa-appliances--{{ section.id }} .tpa-appliances__hero-orb{
      animation: none;
    }
  }
</style>

{%- comment -%} ═══════════════════════════════ JS ═══════════════════════════════ {%- endcomment -%}
<script>
  (function(){
    var section = document.querySelector('.tpa-appliances--{{ section.id }}');
    if (!section) return;

    var reveals = section.querySelectorAll('[data-tpa-app-reveal]');
    var cards   = section.querySelectorAll('[data-tpa-app-card]');
    var all     = [];
    reveals.forEach(function(el){ all.push(el); });
    cards.forEach(function(el){ all.push(el); });
    if (!all.length) return;

    if ('IntersectionObserver' in window){
      var obs = new IntersectionObserver(function(entries){
        entries.forEach(function(entry){
          if (entry.isIntersecting){
            entry.target.classList.add('is-revealed');
            obs.unobserve(entry.target);
          }
        });
      }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
      all.forEach(function(el){ obs.observe(el); });
    } else {
      all.forEach(function(el){ el.classList.add('is-revealed'); });
    }
  })();
</script>

{% schema %}
{
  "name": "TPA Appliances Category",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "pill_text",
      "label": "Hero pill text",
      "default": "APPLIANCES"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Hero heading",
      "default": "Premium Appliances"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Hero description",
      "default": "Quality appliances backed by clear specs, fast Australian shipping, and dedicated local support."
    },
    {
      "type": "text",
      "id": "grid_heading",
      "label": "Grid heading",
      "default": "Browse by Category"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Default accent",
      "default": "#1D5BFF"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Grid width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Grid padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Grid padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Ice Makers"
        },
        {
          "type": "text",
          "id": "kicker",
          "label": "Kicker text",
          "default": "Countertop & Built-In"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Crystal-clear ice on demand — portable, countertop, and built-in models for every kitchen."
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "CTA label",
          "default": "Browse Ice Makers"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon image (optional)"
        },
        {
          "type": "text",
          "id": "fallback_icon",
          "label": "Fallback icon (SVG or emoji)",
          "default": "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.8' stroke-linecap='round' stroke-linejoin='round'><path d='M12 2a4 4 0 0 0-4 4v1H6a2 2 0 0 0-2 2v11a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-2V6a4 4 0 0 0-4-4z'/><line x1='8' y1='12' x2='8' y2='16'/><line x1='12' y1='12' x2='12' y2='16'/><line x1='16' y1='12' x2='16' y2='16'/></svg>"
        },
        {
