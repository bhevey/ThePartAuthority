{% comment %}
  Section: TPA Bundles Grid
  Matches screenshot: dark gradient, 3 bundle cards, optional "Best Value" badge, save pill, add-to-cart CTA, bottom link.
  Uses selected products (one per card). Works with cart page redirect by default.
{% endcomment %}

{% assign sid = section.id %}

<section class="tpa-bundles tpa-bundles--{{ sid }} color-{{ section.settings.color_scheme }}">
  <div class="tpa-bundles__inner {% if section.settings.section_width == 'full-width' %}tpa-bundles__inner--full{% endif %}">
    <header class="tpa-bundles__header">
      <h2 class="tpa-bundles__title">{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
        <p class="tpa-bundles__subtitle">{{ section.settings.subheading }}</p>
      {% endif %}
    </header>

    <div class="tpa-bundles__grid">
      {% for block in section.blocks %}
        {% assign product = block.settings.product %}
        {% if product != blank %}
          {% assign v = product.selected_or_first_available_variant %}
          {% assign price = v.price %}
          {% assign compare = v.compare_at_price %}
          {% assign save_amt = 0 %}
          {% if compare > price %}
            {% assign save_amt = compare | minus: price %}
          {% endif %}

          <article class="tpa-bundle" {{ block.shopify_attributes }} {% if block.settings.featured %}data-featured="true"{% endif %}>
            {% if block.settings.featured %}
              <div class="tpa-bundle__badge">
                <span class="tpa-bundle__crown" aria-hidden="true">👑</span>
                <span>{{ block.settings.badge_text }}</span>
              </div>
            {% endif %}

            <a class="tpa-bundle__media" href="{{ product.url }}">
              {% if block.settings.image != blank %}
                <img
                  src="{{ block.settings.image | image_url: width: 1200 }}"
                  alt="{{ block.settings.title | default: product.title | escape }}"
                  loading="lazy"
                  width="960"
                  height="720"
                >
              {% elsif product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 1200 }}"
                  alt="{{ product.featured_image.alt | default: product.title | escape }}"
                  loading="lazy"
                  width="960"
                  height="720"
                >
              {% endif %}
            </a>

            <div class="tpa-bundle__body">
              <a class="tpa-bundle__title" href="{{ product.url }}">
                {{ block.settings.title | default: product.title }}
              </a>

              {% if block.settings.desc != blank %}
                <div class="tpa-bundle__desc">{{ block.settings.desc }}</div>
              {% elsif product.description != blank %}
                <div class="tpa-bundle__desc">{{ product.description | strip_html | truncate: 82 }}</div>
              {% endif %}

              <div class="tpa-bundle__pricing">
                <div class="tpa-bundle__price">{{ price | money }}</div>
                {% if compare > price %}
                  <div class="tpa-bundle__compare">{{ compare | money }}</div>
                {% endif %}
              </div>

              {% if compare > price %}
                <div class="tpa-bundle__save">
                  Save {{ save_amt | money }}
                </div>
              {% elsif block.settings.save_text != blank %}
                <div class="tpa-bundle__save">
                  {{ block.settings.save_text }}
                </div>
              {% endif %}

              <form method="post" action="{{ routes.cart_add_url }}" class="tpa-bundle__form">
                <input type="hidden" name="id" value="{{ v.id }}">
                <input type="hidden" name="quantity" value="1">
                <button type="submit" class="tpa-bundle__btn" {% unless v.available %}disabled{% endunless %}>
                  <span class="tpa-bundle__btn-ic" aria-hidden="true">🛒</span>
                  <span>
                    {% if v.available %}
                      {{ block.settings.cta_label }}
                    {% else %}
                      {{ section.settings.sold_out_label }}
                    {% endif %}
                  </span>
                </button>
              </form>
            </div>
          </article>
        {% endif %}
      {% endfor %}
    </div>

    {% if section.settings.bottom_link_label != blank %}
      <div class="tpa-bundles__bottom">
        <a class="tpa-bundles__bottom-link" href="{{ section.settings.bottom_link | default: routes.all_products_collection_url }}">
          {{ section.settings.bottom_link_label }}
          <span aria-hidden="true">→</span>
        </a>
      </div>
    {% endif %}
  </div>
</section>

<style>
  .tpa-bundles--{{ sid }}{
    position: relative;
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    background:
      radial-gradient(1100px 640px at 20% 20%, rgba(29,91,255,0.40), rgba(0,0,0,0) 60%),
      linear-gradient(135deg, {{ section.settings.bg_1 }}, {{ section.settings.bg_2 }});
    overflow: hidden;
  }

  .tpa-bundles--{{ sid }}:before{
    content: "";
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.08) 1px, rgba(0,0,0,0) 1.6px);
    background-size: 22px 22px;
    opacity: 0.30;
    pointer-events: none;
    mix-blend-mode: screen;
  }

  .tpa-bundles--{{ sid }} .tpa-bundles__inner{
    position: relative;
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 24px;
    color: #fff;
  }

  .tpa-bundles--{{ sid }} .tpa-bundles__inner--full{
    max-width: none;
    padding: 0 32px;
  }

  .tpa-bundles--{{ sid }} .tpa-bundles__header{
    text-align: center;
    padding-top: 10px;
    margin-bottom: 30px;
  }

  .tpa-bundles--{{ sid }} .tpa-bundles__title{
    margin: 0;
    font-weight: 950;
    letter-spacing: -0.03em;
    font-size: clamp(34px, 4.6vw, 62px);
    line-height: 1.05;
    color: rgba(255,255,255,0.98);
  }

  .tpa-bundles--{{ sid }} .tpa-bundles__subtitle{
    margin: 12px auto 0;
    max-width: 620px;
    font-size: 15px;
    line-height: 1.55;
    color: rgba(255,255,255,0.70);
  }

  .tpa-bundles--{{ sid }} .tpa-bundles__grid{
    margin-top: 26px;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 22px;
    align-items: stretch;
  }

  .tpa-bundles--{{ sid }} .tpa-bundle{
    position: relative;
    border-radius: 18px;
    background: rgba(8, 14, 26, 0.45);
    border: 1px solid rgba(255,255,255,0.10);
    box-shadow:
      0 26px 70px rgba(0,0,0,0.38),
      0 10px 24px rgba(0,0,0,0.25);
    overflow: hidden;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    display: flex;
    flex-direction: column;
    min-height: 520px;
    transition: transform 280ms cubic-bezier(0.16, 1, 0.3, 1), box-shadow 280ms ease, border-color 280ms ease;
  }
  .tpa-bundles--{{ sid }} .tpa-bundle:hover{
    transform: translateY(-6px);
    border-color: rgba(255,255,255,0.20);
    box-shadow:
      0 32px 80px rgba(0,0,0,0.45),
      0 14px 30px rgba(0,0,0,0.30);
  }

  .tpa-bundles--{{ sid }} .tpa-bundle[data-featured="true"]{
    border-color: rgba(29, 91, 255, 0.55);
    box-shadow:
      0 30px 80px rgba(0,0,0,0.42),
      0 0 0 1px rgba(29, 91, 255, 0.15) inset;
  }
  .tpa-bundles--{{ sid }} .tpa-bundle[data-featured="true"]:hover{
    border-color: rgba(29, 91, 255, 0.75);
    box-shadow:
      0 36px 90px rgba(0,0,0,0.48),
      0 0 0 1px rgba(29, 91, 255, 0.25) inset,
      0 0 60px rgba(29, 91, 255, 0.08);
  }

  .tpa-bundles--{{ sid }} .tpa-bundle__badge{
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    border-radius: 999px;
    background: #F59E0B;
    color: #0B1220;
    font-weight: 950;
    font-size: 12px;
    box-shadow: 0 14px 28px rgba(0,0,0,0.35);
    z-index: 2;
    animation: tpaBadgePulse{{ sid }} 2.5s ease-in-out infinite;
  }
  @keyframes tpaBadgePulse{{ sid }}{
    0%, 100%{ box-shadow: 0 14px 28px rgba(0,0,0,0.35); }
    50%{ box-shadow: 0 14px 28px rgba(0,0,0,0.35), 0 0 0 6px rgba(245, 158, 11, 0.20); }
  }

  .tpa-bundles--{{ sid }} .tpa-bundle__crown{
    font-size: 14px;
    line-height: 1;
  }

  .tpa-bundles--{{ sid }} .tpa-bundle__media{
    display: block;
    margin: 18px 18px 0;
    border-radius: 14px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.08);
    padding: 16px;
    min-height: 170px;
  }

  .tpa-bundles--{{ sid }} .tpa-bundle__media img{
    width: 100%;
    height: 170px;
    object-fit: cover;
    border-radius: 12px;
    display: block;
    opacity: 0.92;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease;
  }
  .tpa-bundles--{{ sid }} .tpa-bundle:hover .tpa-bundle__media img{
    transform: scale(1.06);
    opacity: 1;
  }

  .tpa-bundles--{{ sid }} .tpa-bundle__body{
    padding: 18px 18px 18px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .tpa-bundles--{{ sid }} .tpa-bundle__title{
    font-weight: 950;
    letter-spacing: -0.02em;
    font-size: 18px;
    color: rgba(255,255,255,0.96);
    text-decoration: none;
  }

  .tpa-bundles--{{ sid }} .tpa-bundle__desc{
    margin-top: 10px;
    font-size: 13px;
    line-height: 1.55;
    color: rgba(255,255,255,0.62);
    min-height: 42px;
  }

  .tpa-bundles--{{ sid }} .tpa-bundle__pricing{
    margin-top: 20px;
    display: flex;
    align-items: baseline;
    gap: 10px;
  }

  .tpa-bundles--{{ sid }} .tpa-bundle__price{
    font-weight: 950;
    letter-spacing: -0.02em;
    font-size: 30px;
    color: rgba(255,255,255,0.98);
  }

  .tpa-bundles--{{ sid }} .tpa-bundle__compare{
    font-size: 13px;
    color: rgba(255,255,255,0.45);
    text-decoration: line-through;
  }

  .tpa-bundles--{{ sid }} .tpa-bundle__save{
    margin-top: 10px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 26px;
    padding: 0 12px;
    border-radius: 999px;
    background: rgba(16, 185, 129, 0.14);
    border: 1px solid rgba(16, 185, 129, 0.22);
    color: rgba(167, 243, 208, 0.95);
    font-weight: 900;
    font-size: 12px;
    width: fit-content;
  }

  .tpa-bundles--{{ sid }} .tpa-bundle__form{
    margin-top: auto;
    padding-top: 16px;
  }

  .tpa-bundles--{{ sid }} .tpa-bundle__btn{
    width: 100%;
    height: 48px;
    border-radius: 12px;
    border: 1px solid rgba(255,255,255,0.10);
    background: {{ section.settings.cta_bg }};
    color: {{ section.settings.cta_fg }};
    font-weight: 950;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    box-shadow: 0 18px 44px rgba(0,0,0,0.35);
    transition: transform 140ms ease, opacity 140ms ease;
  }

  .tpa-bundles--{{ sid }} .tpa-bundle__btn:hover{
    transform: translateY(-2px);
    box-shadow: 0 20px 50px rgba(29, 91, 255, 0.30), 0 0 0 1px rgba(29, 91, 255, 0.15);
  }
  .tpa-bundles--{{ sid }} .tpa-bundle__btn:active{
    transform: translateY(1px);
  }

  .tpa-bundles--{{ sid }} .tpa-bundle__btn:disabled{
    opacity: 0.55;
    cursor: default;
    box-shadow: none;
  }

  .tpa-bundles--{{ sid }} .tpa-bundle__btn-ic{
    font-size: 16px;
    line-height: 1;
  }

  .tpa-bundles--{{ sid }} .tpa-bundles__bottom{
    margin-top: 28px;
    text-align: center;
  }

  .tpa-bundles--{{ sid }} .tpa-bundles__bottom-link{
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: {{ section.settings.link_color }};
    font-weight: 950;
    text-decoration: none;
    padding: 10px 14px;
    border-radius: 12px;
  }

  .tpa-bundles--{{ sid }} .tpa-bundles__bottom-link:hover{
    text-decoration: underline;
  }

  @media (max-width: 980px){
    .tpa-bundles--{{ sid }} .tpa-bundles__grid{
      grid-template-columns: 1fr;
      max-width: 560px;
      margin-left: auto;
      margin-right: auto;
    }
    .tpa-bundles--{{ sid }} .tpa-bundle{
      min-height: 0;
    }
  }

  @media (prefers-reduced-motion: reduce){
    .tpa-bundles--{{ sid }} .tpa-bundle__btn,
    .tpa-bundles--{{ sid }} .tpa-bundle,
    .tpa-bundles--{{ sid }} .tpa-bundle__media img{
      transition: none;
    }
    .tpa-bundles--{{ sid }} .tpa-bundle__badge{
      animation: none;
    }
  }
</style>

{% schema %}
{
  "name": "TPA Bundles",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Save More with Bundles"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Smart homeowners buy the twin pack. Replace now, keep a spare."
    },
    {
      "type": "color",
      "id": "bg_1",
      "label": "Background 1",
      "default": "#06122C"
    },
    {
      "type": "color",
      "id": "bg_2",
      "label": "Background 2",
      "default": "#071A3A"
    },
    {
      "type": "color",
      "id": "cta_bg",
      "label": "Button background",
      "default": "#1D5BFF"
    },
    {
      "type": "color",
      "id": "cta_fg",
      "label": "Button text",
      "default": "#FFFFFF"
    },
    {
      "type": "text",
      "id": "sold_out_label",
      "label": "Sold out label",
      "default": "Sold out"
    },
    {
      "type": "text",
      "id": "bottom_link_label",
      "label": "Bottom link label",
      "default": "View All Bundles"
    },
    {
      "type": "url",
      "id": "bottom_link",
      "label": "Bottom link"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Bottom link color",
      "default": "#1D5BFF"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 140,
      "step": 4,
      "default": 76
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 140,
      "step": 4,
      "default": 84
    }
  ],
  "blocks": [
    {
      "type": "bundle",
      "name": "Bundle card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card image (optional override)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Card title (optional override)",
          "default": "Bundle name"
        },
        {
          "type": "text",
          "id": "desc",
          "label": "Short description",
          "default": "Bundle description goes here."
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "Button label",
          "default": "Add Bundle to Cart"
        },
        {
          "type": "checkbox",
          "id": "featured",
          "label": "Featured (Best Value)",
          "default": false
        },
        {
          "type": "text",
          "id": "badge_text",
          "label": "Featured badge text",
          "default": "Best Value"
        },
        {
          "type": "text",
          "id": "save_text",
          "label": "Save pill text (only used if no compare-at price)",
          "default": "Save $9.95"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "TPA Bundles",
      "blocks": [
        { "type": "bundle" },
        { "type": "bundle" },
        { "type": "bundle", "settings": { "featured": true, "badge_text": "Best Value" } }
      ]
    }
  ]
}
{% endschema %}