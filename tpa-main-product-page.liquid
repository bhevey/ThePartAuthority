{% comment %}
  Section: TPA Main Product Page
  Design system rules:
  - Uses theme color vars: --color-foreground, etc
  - Uses your established radii, shadows, spacing feel
  - No new visual direction
  - Parts vs Appliances is driven by product tag "Part" or "Appliance"

  Optional metafields (recommended):
  - product.metafields.tpa.subheadline (single_line_text_field)
  - product.metafields.tpa.product_description (rich_text)
  - product.metafields.tpa.specs (rich_text)
  - product.metafields.tpa.warranty (single_line_text_field or rich_text)
  - product.metafields.tpa.shipping_notes (single_line_text_field or rich_text)
  - product.metafields.tpa.install_notes (single_line_text_field or rich_text)
{% endcomment %}

{% assign sid = section.id %}
{% assign is_appliance = false %}
{% if product.tags contains 'Appliance' %}
  {% assign is_appliance = true %}
{% endif %}
{% assign is_part = false %}
{% if product.tags contains 'Part' %}
  {% assign is_part = true %}
{% endif %}
{% if is_appliance == false and is_part == false %}
  {% assign is_part = true %}
{% endif %}

<section class="tpa-pdp tpa-pdp--{{ sid }} color-{{ section.settings.color_scheme }}">
  <div class="tpa-pdp__inner">
    <div class="tpa-pdp__top">
      <div class="tpa-pdp__media">
        <div class="tpa-pdp__gallery" data-tpa-gallery>
          {% assign featured = product.featured_media %}
          {% if featured %}
            <div class="tpa-pdp__stage" data-tpa-stage data-tpa-zoom data-active-media-id="{{ featured.id }}">
              <div class="tpa-pdp__stage-media" data-tpa-stage-media>
                {% render 'tpa-pdp-media', media: featured, index: 0 %}
              </div>
              {% if section.settings.media_badge_enable %}
                <div class="tpa-pdp__media-badge">
                  <span class="tpa-pdp__media-badge-dot" aria-hidden="true"></span>
                  <span>{{ section.settings.media_badge_text }}</span>
                </div>
              {% endif %}
            </div>

            <div class="tpa-pdp__media-templates" hidden>
              {% for media in product.media %}
                <template data-tpa-template="{{ media.id }}">
                  {% render 'tpa-pdp-media', media: media, index: forloop.index0 %}
                </template>
              {% endfor %}
            </div>
          {% endif %}

          {% assign media_count = product.media.size %}
          {% if media_count > 1 %}
            <div class="tpa-pdp__thumbs" aria-label="Product media">
              {% for media in product.media %}
                <button
                  class="tpa-pdp__thumb{% if media.id == featured.id %} is-active{% endif %}"
                  type="button"
                  data-tpa-thumb
                  data-media-id="{{ media.id }}"
                  aria-label="View media {{ forloop.index }}"
                >
                  {% if media.preview_image %}
                    <img
                      src="{{ media.preview_image | image_url: width: 220 }}"
                      alt="{{ media.preview_image.alt | default: product.title | escape }}"
                      loading="lazy"
                      width="84"
                      height="84"
                    >
                  {% endif %}
                </button>
              {% endfor %}
            </div>
          {% endif %}
        </div>

        {% if section.settings.zoom_hint_enable %}
          <div class="tpa-pdp__zoom-hint">{{ section.settings.zoom_hint_text }}</div>
        {% endif %}
      </div>

      <div class="tpa-pdp__buy">
        <h1 class="tpa-pdp__title">{{ product.title }}</h1>

        {% assign subheadline = product.metafields.tpa.subheadline.value %}
        {% if subheadline == blank %}
          {% if is_part %}
            {% assign subheadline = section.settings.part_subheadline_fallback %}
          {% else %}
            {% assign subheadline = section.settings.appliance_subheadline_fallback %}
          {% endif %}
        {% endif %}
        {% if subheadline != blank %}
          <div class="tpa-pdp__subheadline">{{ subheadline }}</div>
        {% endif %}

        <div class="tpa-pdp__rating">
          <div class="tpa-stars" aria-label="{{ section.settings.rating_label }}">
            <span class="tpa-star is-on" aria-hidden="true">★</span>
            <span class="tpa-star is-on" aria-hidden="true">★</span>
            <span class="tpa-star is-on" aria-hidden="true">★</span>
            <span class="tpa-star is-on" aria-hidden="true">★</span>
            <span class="tpa-star is-on" aria-hidden="true">★</span>
          </div>
          <a class="tpa-pdp__rating-link" href="#tpa-reviews-{{ sid }}">{{ section.settings.rating_link_text }}</a>
        </div>

        <div class="tpa-pdp__price-row" data-tpa-price>
          {% assign v = product.selected_or_first_available_variant %}
          {% assign price = v.price %}
          {% assign compare = v.compare_at_price %}
          <div class="tpa-pdp__price">{{ price | money }}</div>
          {% if compare > price %}
            <div class="tpa-pdp__compare">{{ compare | money }}</div>
            <div class="tpa-pdp__save">Save {{ compare | minus: price | money }}</div>
          {% endif %}
        </div>

        {% form 'product', product, class: 'tpa-pdp__form', data-tpa-product-form: '' %}
          <input type="hidden" name="id" value="{{ v.id }}" data-tpa-variant-id>

          {% if product.has_only_default_variant == false %}
            <div class="tpa-pdp__variants">
              {% for option in product.options_with_values %}
                <div class="tpa-pdp__opt">
                  <div class="tpa-pdp__opt-label">{{ option.name }}</div>
                  <div class="tpa-pdp__opt-values">
                    {% for value in option.values %}
                      {% assign checked = false %}
                      {% if option.selected_value == value %}
                        {% assign checked = true %}
                      {% endif %}
                      <label class="tpa-chip">
                        <input
                          type="radio"
                          name="options[{{ option.name | escape }}]"
                          value="{{ value | escape }}"
                          {% if checked %}checked{% endif %}
                        >
                        <span>{{ value }}</span>
                      </label>
                    {% endfor %}
                  </div>
                </div>
              {% endfor %}
            </div>
          {% endif %}

          {% if is_appliance %}
            <div class="tpa-pdp__module tpa-specs">
              <div class="tpa-pdp__module-title">{{ section.settings.specs_title }}</div>

              <div class="tpa-specs__grid">
                <div class="tpa-specs__item">
                  <div class="tpa-specs__k">{{ section.settings.specs_warranty_label }}</div>
                  <div class="tpa-specs__v">
                    {% assign warranty = product.metafields.tpa.warranty.value %}
                    {% if warranty == blank %}
                      {{ section.settings.specs_warranty_fallback }}
                    {% else %}
                      {{ warranty }}
                    {% endif %}
                  </div>
                </div>

                <div class="tpa-specs__item">
                  <div class="tpa-specs__k">{{ section.settings.specs_shipping_label }}</div>
                  <div class="tpa-specs__v">
                    {% assign ship = product.metafields.tpa.shipping_notes.value %}
                    {% if ship == blank %}
                      {{ section.settings.specs_shipping_fallback }}
                    {% else %}
                      {{ ship }}
                    {% endif %}
                  </div>
                </div>

                <div class="tpa-specs__item">
                  <div class="tpa-specs__k">{{ section.settings.specs_setup_label }}</div>
                  <div class="tpa-specs__v">
                    {% assign setup = product.metafields.tpa.install_notes.value %}
                    {% if setup == blank %}
                      {{ section.settings.specs_setup_fallback }}
                    {% else %}
                      {{ setup }}
                    {% endif %}
                  </div>
                </div>

                <div class="tpa-specs__item tpa-specs__item--rich">
                  <div class="tpa-specs__k">{{ section.settings.specs_key_label }}</div>
                  <div class="tpa-specs__v">
                    {% assign specs = product.metafields.tpa.specs.value %}
                    {% if specs == blank %}
                      {{ section.settings.specs_key_fallback }}
                    {% else %}
                      {{ specs }}
                    {% endif %}
                  </div>
                </div>
              </div>
            </div>
          {% endif %}

          <div class="tpa-pdp__qty-row">
            <div class="tpa-qty" data-tpa-qty>
              <button class="tpa-qty__btn" type="button" data-tpa-qty-dec aria-label="Decrease quantity">−</button>
              <input class="tpa-qty__input" type="number" name="quantity" value="1" min="1" inputmode="numeric" data-tpa-qty-input>
              <button class="tpa-qty__btn" type="button" data-tpa-qty-inc aria-label="Increase quantity">+</button>
            </div>

            <button
              class="tpa-btn tpa-btn--primary tpa-pdp__atc"
              type="submit"
              name="add"
              {% unless v.available %}disabled{% endunless %}
              data-tpa-atc
            >
              <span class="tpa-pdp__atc-default">
                <span aria-hidden="true">🛒</span>
                <span>{% if v.available %}{{ section.settings.atc_label }}{% else %}{{ section.settings.sold_out_label }}{% endif %}</span>
              </span>
              <span class="tpa-pdp__atc-success" aria-hidden="true">
                <span>✓</span>
                <span>Added!</span>
              </span>
            </button>
          </div>

          {%- comment -%} Accelerated checkout (Shop Pay, Apple Pay, Google Pay) {%- endcomment -%}
          {% if v.available %}
            <div class="tpa-pdp__dynamic-checkout">
              {{ form | payment_button }}
            </div>
          {% endif %}

          {%- comment -%} Secure checkout badge {%- endcomment -%}
          <div class="tpa-pdp__pay-badges">
            <div class="tpa-pdp__pay-badges-row">
              <svg class="tpa-pdp__pay-lock" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              <span class="tpa-pdp__pay-label">Secure Checkout</span>
            </div>
          </div>

          <div class="tpa-trust">
            {% if is_part %}
              <div class="tpa-trust__item">✔ {{ section.settings.trust_part_1 }}</div>
              <div class="tpa-trust__item">✔ {{ section.settings.trust_part_2 }}</div>
              <div class="tpa-trust__item">✔ {{ section.settings.trust_part_3 }}</div>
              <div class="tpa-trust__item">✔ {{ section.settings.trust_part_4 }}</div>
            {% else %}
              <div class="tpa-trust__item">✔ {{ section.settings.trust_app_1 }}</div>
              <div class="tpa-trust__item">✔ {{ section.settings.trust_app_2 }}</div>
              <div class="tpa-trust__item">✔ {{ section.settings.trust_app_3 }}</div>
              <div class="tpa-trust__item">✔ {{ section.settings.trust_app_4 }}</div>
            {% endif %}
          </div>

          {%- comment -%} Postcode shipping calculator (appliances only) {%- endcomment -%}
          {% if is_appliance %}
            <div class="tpa-pdp__postcode" data-tpa-postcode>
              <div class="tpa-pdp__postcode-header">
                <svg class="tpa-pdp__postcode-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                <span class="tpa-pdp__postcode-title">Calculate Shipping</span>
              </div>
              <div class="tpa-pdp__postcode-form">
                <input
                  class="tpa-pdp__postcode-input"
                  type="text"
                  inputmode="numeric"
                  maxlength="4"
                  pattern="[0-9]{4}"
                  placeholder="Enter postcode"
                  data-tpa-postcode-input
                  aria-label="Australian postcode"
                >
                <button class="tpa-pdp__postcode-btn" type="button" data-tpa-postcode-btn>Check</button>
              </div>
              <div class="tpa-pdp__postcode-result" data-tpa-postcode-result hidden></div>
            </div>
          {% endif %}

          <div class="tpa-pdp__sticky" data-tpa-sticky>
            <div class="tpa-pdp__sticky-left">
              <div class="tpa-pdp__sticky-title">{{ product.title | truncate: 40 }}</div>
              <div class="tpa-pdp__sticky-price">
                {{ price | money }}
                {% if compare > price %}
                  <span class="tpa-pdp__sticky-save">Save {{ compare | minus: price | money }}</span>
                {% endif %}
              </div>
            </div>
            <button class="tpa-btn tpa-btn--primary tpa-pdp__sticky-atc" type="submit" name="add" {% unless v.available %}disabled{% endunless %}>
              <span aria-hidden="true">🛒</span>
              {{ section.settings.atc_label }}
            </button>
          </div>
        {% endform %}
      </div>
    </div>

    {% assign product_description = product.metafields.tpa.product_description.value %}
    {% assign description_content = product_description | default: product.description %}
    {% if description_content != blank %}
      <div class="tpa-pdp__desc">
        <div class="tpa-block__title">{{ section.settings.desc_title }}</div>
        <div class="tpa-pdp__desc-body tpa-rich">
          {{ description_content }}
        </div>
      </div>
    {% endif %}

    <div class="tpa-pdp__mid">
      <div class="tpa-block">
        <div class="tpa-block__title">{{ section.settings.benefits_title }}</div>
        <div class="tpa-block__body">
          {% if is_part %}
            <div class="tpa-kv">{{ section.settings.benefit_part_1 }}</div>
            <div class="tpa-kv">{{ section.settings.benefit_part_2 }}</div>
            <div class="tpa-kv">{{ section.settings.benefit_part_3 }}</div>
            <div class="tpa-kv">{{ section.settings.benefit_part_4 }}</div>
            <div class="tpa-kv">{{ section.settings.benefit_part_5 }}</div>
          {% else %}
            <div class="tpa-kv">{{ section.settings.benefit_app_1 }}</div>
            <div class="tpa-kv">{{ section.settings.benefit_app_2 }}</div>
            <div class="tpa-kv">{{ section.settings.benefit_app_3 }}</div>
            <div class="tpa-kv">{{ section.settings.benefit_app_4 }}</div>
            <div class="tpa-kv">{{ section.settings.benefit_app_5 }}</div>
          {% endif %}
        </div>
      </div>
    </div>

    <div class="tpa-pdp__bundles">
      <div class="tpa-block__title">{{ section.settings.bundles_title }}</div>
      <div class="tpa-bundles-mini" data-product-recommendations
        data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ section.settings.recs_limit }}">
        <div class="tpa-bundles-mini__rail" data-tpa-recs-rail>
          {% comment %}
            Replaced by JS fetch below for speed and accuracy.
          {% endcomment %}
        </div>
      </div>
      {% if section.settings.bundles_link_label != blank %}
        <div class="tpa-bundles-mini__bottom">
          <a class="tpa-bundles-mini__link" href="{{ section.settings.bundles_link | default: routes.all_products_collection_url }}">
            {{ section.settings.bundles_link_label }} <span aria-hidden="true">→</span>
          </a>
        </div>
      {% endif %}
    </div>

    <div class="tpa-risk">
      {% if is_part %}
        <div class="tpa-risk__text">
          {{ section.settings.risk_part }}
        </div>
      {% else %}
        <div class="tpa-risk__text">
          {{ section.settings.risk_app }}
        </div>
      {% endif %}
    </div>

    <div class="tpa-reviews-wrap" id="tpa-reviews-{{ sid }}">
      <div class="tpa-block__title">{{ section.settings.reviews_title }}</div>
      <div class="tpa-reviews-note">{{ section.settings.reviews_note }}</div>
      <div class="tpa-reviews-placeholder">
        {{ section.settings.reviews_placeholder }}
      </div>
    </div>

    {%- comment -%} Recently Viewed Products {%- endcomment -%}
    <div class="tpa-pdp__recently-viewed" data-tpa-recently-viewed hidden>
      <div class="tpa-block__title">Recently Viewed</div>
      <div class="tpa-pdp__rv-rail" data-tpa-rv-rail></div>
    </div>

    <div class="tpa-faq">
      <div class="tpa-block__title">{{ section.settings.faq_title }}</div>

      {% if is_part %}
        <details class="tpa-faq__item" open>
          <summary class="tpa-faq__q">{{ section.settings.faq_part_q1 }}</summary>
          <div class="tpa-faq__a">{{ section.settings.faq_part_a1 }}</div>
        </details>
        <details class="tpa-faq__item">
          <summary class="tpa-faq__q">{{ section.settings.faq_part_q2 }}</summary>
          <div class="tpa-faq__a">{{ section.settings.faq_part_a2 }}</div>
        </details>
        <details class="tpa-faq__item">
          <summary class="tpa-faq__q">{{ section.settings.faq_part_q3 }}</summary>
          <div class="tpa-faq__a">{{ section.settings.faq_part_a3 }}</div>
        </details>
        <details class="tpa-faq__item">
          <summary class="tpa-faq__q">{{ section.settings.faq_part_q4 }}</summary>
          <div class="tpa-faq__a">{{ section.settings.faq_part_a4 }}</div>
        </details>
      {% else %}
        <details class="tpa-faq__item" open>
          <summary class="tpa-faq__q">{{ section.settings.faq_app_q1 }}</summary>
          <div class="tpa-faq__a">{{ section.settings.faq_app_a1 }}</div>
        </details>
        <details class="tpa-faq__item">
          <summary class="tpa-faq__q">{{ section.settings.faq_app_q2 }}</summary>
          <div class="tpa-faq__a">{{ section.settings.faq_app_a2 }}</div>
        </details>
        <details class="tpa-faq__item">
          <summary class="tpa-faq__q">{{ section.settings.faq_app_q3 }}</summary>
          <div class="tpa-faq__a">{{ section.settings.faq_app_a3 }}</div>
        </details>
        <details class="tpa-faq__item">
          <summary class="tpa-faq__q">{{ section.settings.faq_app_q4 }}</summary>
          <div class="tpa-faq__a">{{ section.settings.faq_app_a4 }}</div>
        </details>
      {% endif %}
    </div>
  </div>
</section>

{%- comment -%} JSON-LD STRUCTURED DATA {%- endcomment -%}
{% assign v = product.selected_or_first_available_variant %}
{% assign price = v.price %}
{% assign compare = v.compare_at_price %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": {{ product.title | json }},
  "description": {{ product.description | strip_html | truncate: 5000 | json }},
  "sku": {{ v.sku | json }},
  {% if product.featured_image %}
  "image": [
    {{ product.featured_image | image_url: width: 1200 | json }}{% for media in product.media offset: 1 limit: 4 %}{% if media.preview_image %},
    {{ media.preview_image | image_url: width: 1200 | json }}{% endif %}{% endfor %}
  ],
  {% endif %}
  "brand": {
    "@type": "Brand",
    "name": {{ product.vendor | json }}
  },
  "offers": {
    "@type": "Offer",
    "url": "{{ shop.url }}{{ product.url }}",
    "priceCurrency": {{ cart.currency.iso_code | json }},
    "price": {{ v.price | money_without_currency | remove: ',' | json }},
    {% if compare > price %}
    "priceValidUntil": "{{ 'now' | date: '%Y' | plus: 1 }}-12-31",
    {% endif %}
    "availability": "https://schema.org/{% if v.available %}InStock{% else %}OutOfStock{% endif %}",
    "seller": {
      "@type": "Organization",
      "name": {{ shop.name | json }}
    }
  }
}
</script>

<style>
  .tpa-pdp--{{ sid }}{
    padding: 44px 0 64px;
  }
  .tpa-pdp--{{ sid }} .tpa-pdp__inner{
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .tpa-pdp--{{ sid }} .tpa-pdp__top{
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 34px;
    align-items: start;
  }

  .tpa-pdp--{{ sid }} .tpa-pdp__stage{
    position: relative;
    border-radius: 18px;
    overflow: hidden;
    border: 1px solid rgba(15, 23, 42, 0.10);
    background: rgba(15, 23, 42, 0.04);
    box-shadow:
      0 18px 50px rgba(2, 6, 23, 0.10),
      0 4px 14px rgba(2, 6, 23, 0.06);
  }

  .tpa-pdp--{{ sid }} .tpa-pdp__stage img,
  .tpa-pdp--{{ sid }} .tpa-pdp__stage video,
  .tpa-pdp--{{ sid }} .tpa-pdp__stage iframe{
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease;
  }

  /* --- Image zoom on hover (desktop) --- */
  @media (min-width: 981px){
    .tpa-pdp--{{ sid }} .tpa-pdp__stage[data-tpa-zoom]{
      cursor: zoom-in;
    }
    .tpa-pdp--{{ sid }} .tpa-pdp__stage[data-tpa-zoom]:hover img{
      transform: scale(1.08);
    }
  }

  /* --- Gallery transition when switching media --- */
  .tpa-pdp--{{ sid }} .tpa-pdp__stage.is-switching img,
  .tpa-pdp--{{ sid }} .tpa-pdp__stage.is-switching video{
    opacity: 0;
    transform: scale(0.96);
  }

  .tpa-pdp--{{ sid }} .tpa-pdp__media-badge{
    position: absolute;
    top: 14px;
    left: 14px;
    display: inline-flex;
    gap: 10px;
    align-items: center;
    padding: 8px 12px;
    border-radius: 999px;
    background: rgba(8, 14, 26, 0.70);
    border: 1px solid rgba(255,255,255,0.10);
    color: rgba(255,255,255,0.92);
    font-weight: 900;
    font-size: 12px;
    backdrop-filter: blur(6px);
  }
  .tpa-pdp--{{ sid }} .tpa-pdp__media-badge-dot{
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: rgba(34, 197, 94, 0.95);
    box-shadow: 0 0 0 6px rgba(34, 197, 94, 0.12);
  }

  .tpa-pdp--{{ sid }} .tpa-pdp__thumbs{
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: 84px;
    gap: 10px;
    overflow-x: auto;
    padding: 12px 2px 0;
    scrollbar-width: none;
  }
  .tpa-pdp--{{ sid }} .tpa-pdp__thumbs::-webkit-scrollbar{ display:none; }

  .tpa-pdp--{{ sid }} .tpa-pdp__thumb{
    border-radius: 14px;
    border: 1px solid rgba(15, 23, 42, 0.10);
    background: rgba(15, 23, 42, 0.04);
    padding: 6px;
    cursor: pointer;
    transition: border-color 200ms ease, box-shadow 200ms ease, transform 200ms ease;
  }
  .tpa-pdp--{{ sid }} .tpa-pdp__thumb:hover{
    border-color: rgba(29, 91, 255, 0.30);
    transform: translateY(-2px);
  }
  .tpa-pdp--{{ sid }} .tpa-pdp__thumb.is-active{
    border-color: rgba(29, 91, 255, 0.55);
    box-shadow: 0 0 0 2px rgba(29, 91, 255, 0.14);
  }
  .tpa-pdp--{{ sid }} .tpa-pdp__thumb img{
    width: 100%;
    height: 72px;
    object-fit: cover;
    border-radius: 10px;
    display: block;
  }

  .tpa-pdp--{{ sid }} .tpa-pdp__zoom-hint{
    margin-top: 10px;
    font-size: 12px;
