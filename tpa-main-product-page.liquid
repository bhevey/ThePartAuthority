<script>
  (function(){
    var root = document.querySelector('.tpa-pdp--{{ sid }}');
    if (!root) return;

    /* --- Quantity picker --- */
    var dec = root.querySelector('[data-tpa-qty-dec]');
    var inc = root.querySelector('[data-tpa-qty-inc]');
    var qty = root.querySelector('[data-tpa-qty-input]');
    if (dec && inc && qty){
      dec.addEventListener('click', function(){
        var v = Math.max(1, parseInt(qty.value || '1', 10) - 1);
        qty.value = v;
      });
      inc.addEventListener('click', function(){
        var v = Math.max(1, parseInt(qty.value || '1', 10) + 1);
        qty.value = v;
      });
    }

    /* --- ATC success animation --- */
    var atcBtn = root.querySelector('[data-tpa-atc]');
    var form = root.querySelector('[data-tpa-product-form]');
    if (atcBtn && form){
      form.addEventListener('submit', function(e){
        e.preventDefault();
        atcBtn.classList.add('is-success');
        var formData = new FormData(form);
        fetch('{{ routes.cart_add_url }}.js', {
          method: 'POST',
          body: formData,
          credentials: 'same-origin'
        }).then(function(r){ return r.json(); })
        .then(function(){
          setTimeout(function(){
            atcBtn.classList.remove('is-success');
          }, 1800);
        })
        .catch(function(){
          atcBtn.classList.remove('is-success');
          form.submit();
        });
      });
    }

    /* --- Sticky bar: show when ATC scrolls out of view --- */
    var sticky = root.querySelector('[data-tpa-sticky]');
    if (sticky && atcBtn){
      var stickyObs = new IntersectionObserver(function(entries){
        entries.forEach(function(entry){
          if (entry.isIntersecting){
            sticky.classList.remove('is-visible');
          } else {
            sticky.classList.add('is-visible');
          }
        });
      }, { threshold: 0 });
      stickyObs.observe(atcBtn);
    }

    /* --- Gallery thumbnail switching with transition --- */
    var stage = root.querySelector('[data-tpa-stage]');
    var stageMedia = root.querySelector('[data-tpa-stage-media]');
    var thumbs = root.querySelectorAll('[data-tpa-thumb]');
    if (stage && stageMedia && thumbs.length > 1){
      thumbs.forEach(function(thumb){
        thumb.addEventListener('click', function(){
          var mediaId = thumb.getAttribute('data-media-id');
          var template = root.querySelector('[data-tpa-template="' + mediaId + '"]');
          if (!template) return;
          if (stage.getAttribute('data-active-media-id') === mediaId) return;
          thumbs.forEach(function(t){ t.classList.remove('is-active'); });
          thumb.classList.add('is-active');
          stage.classList.add('is-switching');
          setTimeout(function(){
            stageMedia.innerHTML = template.innerHTML;
            stage.setAttribute('data-active-media-id', mediaId);
            stage.classList.remove('is-switching');
          }, 300);
        });
      });
    }

    /* --- Fit checker --- */
    var fit = root.querySelector('[data-tpa-fit]');
    if (fit){
      var input = root.querySelector('[data-tpa-fit-input]');
      var check = root.querySelector('[data-tpa-fit-check]');
      var text = root.querySelector('[data-tpa-fit-text]');

      function setState(state, label){
        fit.setAttribute('data-state', state);
        if (text) text.textContent = label;
      }

      function evaluate(value){
        var v = (value || '').trim();
        if (v.length < 3) {
          setState('warn', {{ section.settings.fit_state_warn | json }});
          return;
        }
        var chips = Array.prototype.slice.call(root.querySelectorAll('[data-tpa-fit-chip]'));
        var match = chips.some(function(b){
          return (b.getAttribute('data-tpa-fit-chip') || '').toLowerCase() === v.toLowerCase();
        });
        if (match){
          setState('good', {{ section.settings.fit_state_good | json }});
        } else {
          setState('bad', {{ section.settings.fit_state_bad | json }});
        }
      }

      if (check) check.addEventListener('click', function(){ evaluate(input.value); });
      if (input) input.addEventListener('input', function(){ evaluate(input.value); });

      root.addEventListener('click', function(e){
        var chip = e.target.closest('.tpa-fit__chip');
        if (!chip) return;
        var val = chip.getAttribute('data-tpa-fit-chip') || chip.textContent;
        if (input) input.value = val;
        evaluate(val);
      });

      setState('warn', {{ section.settings.fit_state_default | json }});
    }

    /* --- Product recommendations --- */
    var recHost = root.querySelector('[data-product-recommendations]');
    if (recHost){
      var url = recHost.getAttribute('data-url');
      fetch(url, { credentials: 'same-origin' })
        .then(function(r){ return r.text(); })
        .then(function(html){
          var doc = new DOMParser().parseFromString(html, 'text/html');
          var products = doc.querySelectorAll('[data-tpa-rec-card]');
          var rail = recHost.querySelector('[data-tpa-recs-rail]');
          if (!rail || !products.length) return;

          products.forEach(function(node){
            rail.appendChild(node);
          });
        })
        .catch(function(){});
    }
  })();
</script>

