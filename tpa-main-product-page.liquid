  .tpa-pdp--{{ sid }} .tpa-pdp__postcode-rate{
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 4px 0;
  }
  .tpa-pdp--{{ sid }} .tpa-pdp__postcode-rate + .tpa-pdp__postcode-rate{
    border-top: 1px solid rgba(29, 91, 255, 0.08);
    margin-top: 4px;
    padding-top: 8px;
  }
  .tpa-pdp--{{ sid }} .tpa-pdp__postcode-rate-name{
    font-weight: 800;
    font-size: 13px;
  }
  .tpa-pdp--{{ sid }} .tpa-pdp__postcode-rate-price{
    font-weight: 950;
    font-size: 13px;
    color: rgba(29, 91, 255, 0.95);
  }
  .tpa-pdp--{{ sid }} .tpa-pdp__postcode-rate-price--free{
    color: rgba(22, 163, 74, 0.95);
  }

  /* ── RECENTLY VIEWED ── */
  .tpa-pdp--{{ sid }} .tpa-pdp__recently-viewed{
    margin-top: 22px;
  }
  .tpa-pdp--{{ sid }} .tpa-pdp__recently-viewed[hidden]{ display: none; }
  .tpa-pdp--{{ sid }} .tpa-pdp__rv-rail{
    margin-top: 12px;
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(200px, 1fr);
    gap: 14px;
    overflow-x: auto;
    padding: 4px 2px 10px;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }
  .tpa-pdp--{{ sid }} .tpa-pdp__rv-rail::-webkit-scrollbar{ display: none; }
  .tpa-pdp--{{ sid }} .tpa-pdp__rv-card{
    scroll-snap-align: start;
    border-radius: 16px;
    border: 1px solid rgba(15, 23, 42, 0.10);
    background: rgba(255,255,255,0.90);
    box-shadow: 0 14px 40px rgba(2, 6, 23, 0.06), 0 4px 12px rgba(2, 6, 23, 0.04);
    overflow: hidden;
    text-decoration: none;
    display: block;
    transition: transform 200ms ease, box-shadow 200ms ease;
  }
  .tpa-pdp--{{ sid }} .tpa-pdp__rv-card:hover{
    transform: translateY(-3px);
    box-shadow: 0 18px 48px rgba(2, 6, 23, 0.10);
  }
  .tpa-pdp--{{ sid }} .tpa-pdp__rv-img{
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    display: block;
    background: rgba(15, 23, 42, 0.04);
  }
  .tpa-pdp--{{ sid }} .tpa-pdp__rv-info{
    padding: 12px;
  }
  .tpa-pdp--{{ sid }} .tpa-pdp__rv-title{
    font-weight: 950;
    font-size: 13px;
    color: rgb(var(--color-foreground));
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .tpa-pdp--{{ sid }} .tpa-pdp__rv-price{
    margin-top: 6px;
    font-weight: 950;
    font-size: 15px;
    color: rgba(var(--color-foreground), 0.88);
  }

  @media (max-width: 980px){
    .tpa-pdp--{{ sid }} .tpa-pdp__top{
      grid-template-columns: 1fr;
      gap: 18px;
    }
    .tpa-pdp--{{ sid }} .tpa-pdp__qty-row{
      grid-template-columns: 1fr;
    }
    .tpa-pdp--{{ sid }} .tpa-trust{
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 767px){
    .tpa-pdp--{{ sid }}{
      padding: 20px 0 40px;
    }
    .tpa-pdp--{{ sid }} .tpa-pdp__inner{
      padding: 0 16px;
    }
    .tpa-pdp--{{ sid }} .tpa-pdp__title{
      font-size: clamp(22px, 6vw, 30px);
    }
    .tpa-pdp--{{ sid }} .tpa-pdp__desc{
      padding: 16px;
    }
    .tpa-pdp--{{ sid }} .tpa-block{
      padding: 14px;
    }
    .tpa-pdp--{{ sid }} .tpa-pdp__mid{
      margin-top: 20px;
    }
    .tpa-pdp--{{ sid }} .tpa-pdp__bundles{
      margin-top: 16px;
    }
  }
</style>

<script>
  (function(){
    var root = document.querySelector('.tpa-pdp--{{ sid }}');
    if (!root) return;

    /* --- Quantity picker --- */
    var dec = root.querySelector('[data-tpa-qty-dec]');
    var inc = root.querySelector('[data-tpa-qty-inc]');
    var qty = root.querySelector('[data-tpa-qty-input]');
    if (dec && inc && qty){
      dec.addEventListener('click', function(){
        var v = Math.max(1, parseInt(qty.value || '1', 10) - 1);
        qty.value = v;
      });
      inc.addEventListener('click', function(){
        var v = Math.max(1, parseInt(qty.value || '1', 10) + 1);
        qty.value = v;
      });
    }

    /* --- ATC success animation --- */
    var atcBtn = root.querySelector('[data-tpa-atc]');
    var form = root.querySelector('[data-tpa-product-form]');
    if (atcBtn && form){
      form.addEventListener('submit', function(e){
        e.preventDefault();
        atcBtn.classList.add('is-success');
        var formData = new FormData(form);
        fetch('{{ routes.cart_add_url }}.js', {
          method: 'POST',
          body: formData,
          credentials: 'same-origin'
        }).then(function(r){ return r.json(); })
        .then(function(){
          setTimeout(function(){
            atcBtn.classList.remove('is-success');
          }, 1800);
        })
        .catch(function(){
          atcBtn.classList.remove('is-success');
          form.submit();
        });
      });
    }

    /* --- Sticky bar: show when ATC scrolls out of view --- */
    var sticky = root.querySelector('[data-tpa-sticky]');
    if (sticky && atcBtn){
      var stickyObs = new IntersectionObserver(function(entries){
        entries.forEach(function(entry){
          if (entry.isIntersecting){
            sticky.classList.remove('is-visible');
          } else {
            sticky.classList.add('is-visible');
          }
        });
      }, { threshold: 0 });
      stickyObs.observe(atcBtn);
    }

    /* --- Gallery thumbnail switching with transition --- */
    var stage = root.querySelector('[data-tpa-stage]');
    var stageMedia = root.querySelector('[data-tpa-stage-media]');
    var thumbs = root.querySelectorAll('[data-tpa-thumb]');
    if (stage && stageMedia && thumbs.length > 1){
      thumbs.forEach(function(thumb){
        thumb.addEventListener('click', function(){
          var mediaId = thumb.getAttribute('data-media-id');
          var template = root.querySelector('[data-tpa-template="' + mediaId + '"]');
          if (!template) return;
          if (stage.getAttribute('data-active-media-id') === mediaId) return;
          thumbs.forEach(function(t){ t.classList.remove('is-active'); });
          thumb.classList.add('is-active');
          stage.classList.add('is-switching');
          setTimeout(function(){
            stageMedia.innerHTML = template.innerHTML;
            stage.setAttribute('data-active-media-id', mediaId);
            stage.classList.remove('is-switching');
          }, 300);
        });
      });
    }

    /* --- Postcode shipping calculator (appliances) --- */
    var postcodeInput = root.querySelector('[data-tpa-postcode-input]');
    var postcodeBtn = root.querySelector('[data-tpa-postcode-btn]');
    var postcodeResult = root.querySelector('[data-tpa-postcode-result]');

    if (postcodeInput && postcodeBtn && postcodeResult){
      var variantIdInput = root.querySelector('[data-tpa-variant-id]');

      /* Poll Shopify shipping rates endpoint — it returns 422 while calculating */
      function pollShippingRates(postcode, attempt){
        var maxAttempts = 15;
        if (attempt > maxAttempts){
          return Promise.reject(new Error('timeout after ' + maxAttempts + ' attempts'));
        }

        var ratesUrl = '/cart/shipping_rates.json?shipping_address[zip]=' + encodeURIComponent(postcode)
          + '&shipping_address[country]=Australia'
          + '&shipping_address[province]=';

        return fetch(ratesUrl, { credentials: 'same-origin' })
          .then(function(r){
            if (r.status === 422){
              /* Exponential backoff: 800, 1200, 1800, 2700… capped at 4000ms */
              var delay = Math.min(800 * Math.pow(1.5, attempt - 1), 4000);
              return new Promise(function(resolve){
                setTimeout(resolve, delay);
              }).then(function(){
                return pollShippingRates(postcode, attempt + 1);
              });
            }
            if (!r.ok){
              return r.text().then(function(body){
                throw new Error('Rates HTTP ' + r.status + ': ' + body.substring(0, 200));
              });
            }
            return r.json();
          });
      }

      function fetchShippingRates(postcode){
        postcodeBtn.disabled = true;
        postcodeBtn.textContent = '...';
        postcodeResult.hidden = true;
        postcodeResult.className = 'tpa-pdp__postcode-result';

        var vid = variantIdInput ? variantIdInput.value : {{ product.selected_or_first_available_variant.id | json }};
        var savedCart = null;
        var debugSteps = [];

        fetch('/cart.js', { credentials: 'same-origin' })
        .then(function(r){
          debugSteps.push('1-cart-get: ' + r.status);
          if (!r.ok) throw new Error('Cart GET failed: ' + r.status);
          return r.json();
        })
        .then(function(cart){
          savedCart = cart;
          debugSteps.push('1-cart-items: ' + (cart.items ? cart.items.length : 0));

          return fetch('/cart/add.js', {
            method: 'POST',
            credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: parseInt(vid, 10), quantity: 1 })
          });
        })
        .then(function(r){
          debugSteps.push('2-cart-add: ' + r.status);
          if (!r.ok) return r.text().then(function(t){ throw new Error('Cart ADD failed: ' + r.status + ' ' + t); });
          return r.json();
        })
        .then(function(addResult){
          debugSteps.push('2-added-id: ' + (addResult.variant_id || addResult.id || 'unknown'));
          return pollShippingRates(postcode, 1);
        })
        .then(function(data){
          debugSteps.push('3-rates-ok');
          var rates = data.shipping_rates || [];
          if (!rates.length){
            postcodeResult.className = 'tpa-pdp__postcode-result tpa-pdp__postcode-result--error';
            postcodeResult.innerHTML = 'No shipping rates available for this postcode. Please contact us for a quote.';
            postcodeResult.hidden = false;
            return;
          }

          var hasFree = rates.some(function(r){ return parseFloat(r.price) === 0; });

          if (hasFree){
            postcodeResult.className = 'tpa-pdp__postcode-result tpa-pdp__postcode-result--success';
            postcodeResult.innerHTML = '<strong>Free delivery to ' + postcode + '!</strong>';
          } else {
            var html = '';
            rates.forEach(function(rate){
              var ratePrice = parseFloat(rate.price);
              var priceClass = ratePrice === 0 ? 'tpa-pdp__postcode-rate-price tpa-pdp__postcode-rate-price--free' : 'tpa-pdp__postcode-rate-price';
              var priceText = ratePrice === 0 ? 'FREE' : '$' + ratePrice.toFixed(2);
              html += '<div class="tpa-pdp__postcode-rate">';
              html += '<span class="tpa-pdp__postcode-rate-name">' + rate.name + '</span>';
              html += '<span class="' + priceClass + '">' + priceText + '</span>';
              html += '</div>';
            });
            postcodeResult.className = 'tpa-pdp__postcode-result tpa-pdp__postcode-result--rates';
            postcodeResult.innerHTML = html;
          }

          postcodeResult.hidden = false;
        })
        .catch(function(err){
          postcodeResult.className = 'tpa-pdp__postcode-result tpa-pdp__postcode-result--error';
          postcodeResult.innerHTML = '<strong>Shipping calculation error</strong><br><small style="opacity:.7">Debug: ' + debugSteps.join(' → ') + ' → ERR: ' + (err && err.message ? err.message : String(err)) + '</small>';
          postcodeResult.hidden = false;
          console.error('TPA Shipping Debug:', debugSteps, err);
        })
        .finally(function(){
          var doRestore = function(){
            if (!savedCart) return Promise.resolve();

            return fetch('/cart/clear.js', {
              method: 'POST',
              credentials: 'same-origin',
              headers: { 'Content-Type': 'application/json' }
            })
            .then(function(){
              if (savedCart.items && savedCart.items.length){
                var addItems = savedCart.items.map(function(item){
                  return { id: item.variant_id, quantity: item.quantity };
                });
                return fetch('/cart/add.js', {
                  method: 'POST',
                  credentials: 'same-origin',
                  headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ items: addItems })
                });
              }
            })
            .catch(function(){});
          };

          doRestore().then(function(){
            postcodeBtn.disabled = false;
            postcodeBtn.textContent = 'Check';
          });
        });
      }

      postcodeBtn.addEventListener('click', function(){
        var postcode = postcodeInput.value.trim();
        if (!/^\d{4}$/.test(postcode)){
          postcodeResult.className = 'tpa-pdp__postcode-result tpa-pdp__postcode-result--error';
          postcodeResult.innerHTML = 'Please enter a valid 4-digit Australian postcode.';
          postcodeResult.hidden = false;
          return;
        }
        fetchShippingRates(postcode);
      });

      postcodeInput.addEventListener('keydown', function(e){
        if (e.key === 'Enter'){
          e.preventDefault();
          postcodeBtn.click();
        }
      });
    }

    /* --- Recently Viewed Products --- */
    var rvSection = root.querySelector('[data-tpa-recently-viewed]');
    var rvRail = root.querySelector('[data-tpa-rv-rail]');

    if (rvSection && rvRail){
      var RV_KEY = 'tpa_recently_viewed';
      var MAX_RV = 8;
      var currentHandle = {{ product.handle | json }};
      var currentProduct = {
        handle: currentHandle,
        title: {{ product.title | json }},
        url: {{ product.url | json }},
        price: {{ product.selected_or_first_available_variant.price | money | json }},
        image: {{ product.featured_image | image_url: width: 400 | json }}
      };

      try {
        var stored = JSON.parse(localStorage.getItem(RV_KEY) || '[]');
        stored = stored.filter(function(p){ return p.handle !== currentHandle; });
        stored.unshift(currentProduct);
        if (stored.length > MAX_RV) stored = stored.slice(0, MAX_RV);
        localStorage.setItem(RV_KEY, JSON.stringify(stored));

        var toShow = stored.filter(function(p){ return p.handle !== currentHandle; });
        if (toShow.length > 0){
          var html = '';
          toShow.forEach(function(p){
            html += '<a class="tpa-pdp__rv-card" href="' + p.url + '">';
            if (p.image){
              html += '<img class="tpa-pdp__rv-img" src="' + p.image + '" alt="' + p.title.replace(/"/g, '&quot;') + '" loading="lazy" width="200" height="200">';
            }
            html += '<div class="tpa-pdp__rv-info">';
            html += '<div class="tpa-pdp__rv-title">' + p.title + '</div>';
            html += '<div class="tpa-pdp__rv-price">' + p.price + '</div>';
            html += '</div></a>';
          });
          rvRail.innerHTML = html;
          rvSection.hidden = false;
        }
      } catch(e){}
    }

    /* --- Product recommendations --- */
    var recHost = root.querySelector('[data-product-recommendations]');
    if (recHost){
      var url = recHost.getAttribute('data-url');
      fetch(url, { credentials: 'same-origin' })
        .then(function(r){ return r.text(); })
        .then(function(html){
          var doc = new DOMParser().parseFromString(html, 'text/html');
          var products = doc.querySelectorAll('[data-tpa-rec-card]');
          var rail = recHost.querySelector('[data-tpa-recs-rail]');
          if (!rail || !products.length) return;

          products.forEach(function(node){
            rail.appendChild(node);
          });
        })
        .catch(function(){});
    }
  })();
</script>

