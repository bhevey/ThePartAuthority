    border: 2.5px solid rgba(29, 91, 255, 0.15);
    border-top-color: #1D5BFF;
    border-radius: 50%;
    animation: tpaShipSpin 0.6s linear infinite;
  }
  @keyframes tpaShipSpin{
    to{ transform: rotate(360deg); }
  }
  .tpa-lp--{{ sid }} .tpa-lp__ship-est-error{
    color: #dc2626;
    font-weight: 600;
    font-size: 13px;
    padding: 8px 12px;
    background: rgba(220, 38, 38, 0.06);
    border-radius: 8px;
  }
  .tpa-lp--{{ sid }} .tpa-lp__ship-est-fallback{
    color: rgba(var(--color-foreground), 0.5);
    font-weight: 600;
    font-size: 13px;
    padding: 8px 0;
  }

  /* ── PAYMENT BADGES ── */
  .tpa-lp--{{ sid }} .tpa-lp__pay-badges{
    margin-top: 12px;
  }
  .tpa-lp--{{ sid }} .tpa-lp__pay-badges-row{
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .tpa-lp--{{ sid }} .tpa-lp__pay-lock{
    color: rgba(22, 163, 74, 0.85);
    flex-shrink: 0;
  }
  .tpa-lp--{{ sid }} .tpa-lp__pay-label{
    font-size: 11px;
    font-weight: 900;
    color: rgba(var(--color-foreground), 0.55);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  /* ── RECENTLY VIEWED ── */
  .tpa-lp--{{ sid }} .tpa-lp__recently-viewed{
    margin-top: 32px;
  }
  .tpa-lp--{{ sid }} .tpa-lp__recently-viewed[hidden]{ display: none; }
  .tpa-lp--{{ sid }} .tpa-lp__rv-rail{
    margin-top: 18px;
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(200px, 1fr);
    gap: 14px;
    overflow-x: auto;
    padding: 4px 2px 10px;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }
  .tpa-lp--{{ sid }} .tpa-lp__rv-rail::-webkit-scrollbar{ display: none; }
  .tpa-lp--{{ sid }} .tpa-lp__rv-card{
    scroll-snap-align: start;
    border-radius: 16px;
    border: 1px solid rgba(15, 23, 42, 0.10);
    background: rgba(255,255,255,0.90);
    box-shadow: 0 14px 40px rgba(2, 6, 23, 0.06), 0 4px 12px rgba(2, 6, 23, 0.04);
    overflow: hidden;
    text-decoration: none;
    display: block;
    transition: transform 200ms ease, box-shadow 200ms ease;
  }
  .tpa-lp--{{ sid }} .tpa-lp__rv-card:hover{
    transform: translateY(-3px);
    box-shadow: 0 18px 48px rgba(2, 6, 23, 0.10);
  }
  .tpa-lp--{{ sid }} .tpa-lp__rv-img{
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    display: block;
    background: rgba(15, 23, 42, 0.04);
  }
  .tpa-lp--{{ sid }} .tpa-lp__rv-info{
    padding: 12px;
  }
  .tpa-lp--{{ sid }} .tpa-lp__rv-title{
    font-weight: 950;
    font-size: 13px;
    color: rgb(var(--color-foreground));
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .tpa-lp--{{ sid }} .tpa-lp__rv-price{
    margin-top: 6px;
    font-weight: 950;
    font-size: 15px;
    color: rgba(var(--color-foreground), 0.88);
  }

  /* ══════════ RESPONSIVE ══════════ */
  @media (max-width: 980px){
    .tpa-lp--{{ sid }}{
      padding: 0 0 88px;
    }

    .tpa-lp--{{ sid }} .tpa-lp__inner{
      padding: 0 18px;
    }

    .tpa-lp--{{ sid }} .tpa-lp__hero{
      grid-template-columns: 1fr;
      gap: 22px;
      padding-top: 22px;
    }

    .tpa-lp--{{ sid }} .tpa-lp__proof-bar{
      grid-template-columns: 1fr 1fr;
      gap: 14px;
    }

    .tpa-lp--{{ sid }} .tpa-lp__proof-divider{
      display: none;
    }

    .tpa-lp--{{ sid }} .tpa-lp__guarantees-grid{
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .tpa-lp--{{ sid }} .tpa-lp__details-grid{
      grid-template-columns: 1fr;
    }

    .tpa-lp--{{ sid }} .tpa-lp__specs-grid{
      grid-template-columns: 1fr 1fr;
    }

    .tpa-lp--{{ sid }} .tpa-lp__buy-row{
      grid-template-columns: 1fr;
      gap: 10px;
    }

    .tpa-lp--{{ sid }} .tpa-lp__qty{
      width: 100%;
    }

    .tpa-lp--{{ sid }} .tpa-lp__trust-strip{
      grid-template-columns: 1fr;
    }

    .tpa-lp--{{ sid }} .tpa-lp__guarantees,
    .tpa-lp--{{ sid }} .tpa-lp__faq,
    .tpa-lp--{{ sid }} .tpa-lp__detail-card,
    .tpa-lp--{{ sid }} .tpa-lp__description-card,
    .tpa-lp--{{ sid }} .tpa-lp__final-cta{
      padding: 20px;
    }
  }

  @media (max-width: 640px){
    .tpa-lp--{{ sid }} .tpa-lp__inner{
      padding: 0 14px;
    }

    .tpa-lp--{{ sid }} .tpa-lp__title{
      font-size: 30px;
      line-height: 1.1;
    }

    .tpa-lp--{{ sid }} .tpa-lp__subheadline{
      font-size: 14px;
      line-height: 1.6;
    }

    .tpa-lp--{{ sid }} .tpa-lp__price{
      font-size: 28px;
    }

    .tpa-lp--{{ sid }} .tpa-lp__proof-bar{
      grid-template-columns: 1fr 1fr;
      padding: 18px 14px;
    }

    .tpa-lp--{{ sid }} .tpa-lp__guarantees-grid{
      grid-template-columns: 1fr;
    }

    .tpa-lp--{{ sid }} .tpa-lp__reviews-grid{
      grid-template-columns: 1fr;
    }

    .tpa-lp--{{ sid }} .tpa-lp__specs-grid{
      grid-template-columns: 1fr;
    }

    .tpa-lp--{{ sid }} .tpa-lp__thumbs{
      grid-auto-columns: 72px;
      gap: 8px;
      padding-top: 10px;
    }

    .tpa-lp--{{ sid }} .tpa-lp__thumb img{
      height: 60px;
    }

    .tpa-lp--{{ sid }} .tpa-lp__sticky{
      padding: 10px 14px calc(10px + env(safe-area-inset-bottom));
      gap: 10px;
    }

    .tpa-lp--{{ sid }} .tpa-lp__sticky-left{
      min-width: 0;
      flex: 1 1 auto;
    }

    .tpa-lp--{{ sid }} .tpa-lp__sticky-title{
      font-size: 12px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .tpa-lp--{{ sid }} .tpa-lp__sticky-atc{
      height: 42px;
      padding: 0 16px;
      font-size: 12px;
    }

    .tpa-lp--{{ sid }} .tpa-lp__description-body{
      font-size: 14px;
      line-height: 1.7;
    }
  }

  /* ══════════ REDUCED MOTION ══════════ */
  @media (prefers-reduced-motion: reduce){
    .tpa-lp--{{ sid }} .tpa-lp__announce-dot,
    .tpa-lp--{{ sid }} .tpa-lp__activity-dot,
    .tpa-lp--{{ sid }} .tpa-lp__stock-dot,
    .tpa-lp--{{ sid }} .tpa-lp__media-badge-dot{
      animation: none;
    }
    .tpa-lp--{{ sid }} .tpa-lp__sale-flag{
      animation: none;
    }
    .tpa-lp--{{ sid }} .tpa-lp__atc-shimmer,
    .tpa-lp--{{ sid }} .tpa-lp__final-btn-shimmer,
    .tpa-lp--{{ sid }} .tpa-lp__final-orb{
      animation: none;
    }
    .tpa-lp--{{ sid }} .tpa-lp__guarantee,
    .tpa-lp--{{ sid }} .tpa-lp__review{
      opacity: 1;
      transform: none;
    }
    .tpa-lp--{{ sid }} .tpa-lp__sticky{
      transition: none;
    }
  }
</style>

<script>
(function(){
  var sid = {{ sid | json }};
  var root = document.querySelector('.tpa-lp--' + sid);
  if (!root) return;

  /* ── Quantity picker ── */
  var dec = root.querySelector('[data-tpa-lp-qty-dec]');
  var inc = root.querySelector('[data-tpa-lp-qty-inc]');
  var qty = root.querySelector('[data-tpa-lp-qty-input]');
  if (dec && inc && qty){
    dec.addEventListener('click', function(){
      qty.value = Math.max(1, parseInt(qty.value || '1', 10) - 1);
    });
    inc.addEventListener('click', function(){
      qty.value = Math.max(1, parseInt(qty.value || '1', 10) + 1);
    });
  }

  var atcBtn = root.querySelector('[data-tpa-lp-atc]');
  var stickyAtcBtn = root.querySelector('.tpa-lp__sticky-atc');
  var form = root.querySelector('[data-tpa-lp-form]');
  var variantInput = root.querySelector('[data-tpa-lp-variant-id]');
  var optionInputs = root.querySelectorAll('.tpa-lp__variants input[type="radio"]');
  var variants = {{ product.variants | json }};

  /* ── Update hidden variant ID when options change ── */
  function updateVariantId(){
    if (!variantInput || !variants || !variants.length) return;

    var selectedOptions = [];
    var groups = root.querySelectorAll('.tpa-lp__opt');

    groups.forEach(function(group){
      var checked = group.querySelector('input[type="radio"]:checked');
      if (checked) selectedOptions.push(checked.value);
    });

    var matched = variants.find(function(variant){
      return JSON.stringify(variant.options) === JSON.stringify(selectedOptions);
    });

    if (matched){
      variantInput.value = matched.id;

      if (atcBtn){
        atcBtn.disabled = !matched.available;
        atcBtn.querySelector('.tpa-lp__atc-default span:last-child').textContent = matched.available
          ? {{ section.settings.atc_label | json }}
          : {{ section.settings.sold_out_label | json }};
      }

      if (stickyAtcBtn){
        stickyAtcBtn.disabled = !matched.available;
      }
    }
  }

  if (optionInputs.length){
    optionInputs.forEach(function(input){
      input.addEventListener('change', updateVariantId);
    });
    updateVariantId();
  }

  /* ── Native Shopify add to cart ── */
  if (atcBtn && form){
    form.addEventListener('submit', function(){
      if (!atcBtn.disabled){
        atcBtn.classList.add('is-loading');
      }
      if (stickyAtcBtn && !stickyAtcBtn.disabled){
        stickyAtcBtn.classList.add('is-loading');
      }

      setTimeout(function(){
        atcBtn.classList.remove('is-loading');
        if (stickyAtcBtn){
          stickyAtcBtn.classList.remove('is-loading');
        }
      }, 2000);
    });
  }

  /* ── Sticky bar: show when ATC scrolls out of view ── */
  var sticky = root.querySelector('[data-tpa-lp-sticky]');
  if (sticky && atcBtn){
    var stickyObs = new IntersectionObserver(function(entries){
      entries.forEach(function(entry){
        if (entry.isIntersecting){
          sticky.classList.remove('is-visible');
        } else {
          sticky.classList.add('is-visible');
        }
      });
    }, { threshold: 0 });
    stickyObs.observe(atcBtn);
  }

    /* ── Gallery thumbnail switching + swipe + fullscreen ── */
  var stage = root.querySelector('[data-tpa-lp-stage]');
  var stageMedia = root.querySelector('[data-tpa-lp-stage-media]');
  var thumbs = Array.prototype.slice.call(root.querySelectorAll('[data-tpa-lp-thumb]'));
  var lightbox = root.querySelector('[data-tpa-lp-lightbox]');
  var lightboxMedia = root.querySelector('[data-tpa-lp-lightbox-media]');
  var lightboxPrev = root.querySelector('[data-tpa-lp-lightbox-prev]');
  var lightboxNext = root.querySelector('[data-tpa-lp-lightbox-next]');
  var lightboxCloseBtns = root.querySelectorAll('[data-tpa-lp-lightbox-close]');
  var mediaIds = thumbs.map(function(thumb){
    return thumb.getAttribute('data-media-id');
  });

  function getActiveMediaId(){
    return stage ? stage.getAttribute('data-active-media-id') : null;
  }

  function getActiveIndex(){
    var activeId = getActiveMediaId();
    return mediaIds.indexOf(activeId);
  }

  function swapMediaById(mediaId){
    var template = root.querySelector('[data-tpa-lp-template="' + mediaId + '"]');
    if (!template || !stage || !stageMedia) return;
    if (stage.getAttribute('data-active-media-id') === mediaId) return;

    thumbs.forEach(function(t){
      t.classList.remove('is-active');
    });

    var activeThumb = root.querySelector('[data-tpa-lp-thumb][data-media-id="' + mediaId + '"]');
    if (activeThumb){
      activeThumb.classList.add('is-active');
      activeThumb.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'nearest' });
    }

    stage.classList.add('is-switching');

    setTimeout(function(){
      stageMedia.innerHTML = template.innerHTML;
      stage.setAttribute('data-active-media-id', mediaId);
      stage.classList.remove('is-switching');

      if (lightbox && !lightbox.hasAttribute('hidden') && lightboxMedia){
        lightboxMedia.innerHTML = template.innerHTML;
      }

      if (typeof updateThumbArrows === 'function') updateThumbArrows();
    }, 180);
  }

  function swapToIndex(index){
    if (!mediaIds.length) return;
    if (index < 0) index = mediaIds.length - 1;
    if (index >= mediaIds.length) index = 0;
    swapMediaById(mediaIds[index]);
  }

  if (stage && stageMedia && thumbs.length > 1){
    thumbs.forEach(function(thumb){
      thumb.addEventListener('click', function(){
        var mediaId = thumb.getAttribute('data-media-id');
        swapMediaById(mediaId);
      });
    });
  }

  /* ── Stage (main image) prev/next arrows ── */
  var stagePrev = root.querySelector('[data-tpa-lp-stage-prev]');
  var stageNext = root.querySelector('[data-tpa-lp-stage-next]');

  if (stagePrev){
    stagePrev.addEventListener('click', function(e){
      e.stopPropagation();
      swapToIndex(getActiveIndex() - 1);
    });
  }
  if (stageNext){
    stageNext.addEventListener('click', function(e){
      e.stopPropagation();
      swapToIndex(getActiveIndex() + 1);
    });
  }

  /* ── Thumbnail scroll arrows ── */
  var thumbsScroll = root.querySelector('[data-tpa-lp-thumbs-scroll]');
  var thumbsPrev = root.querySelector('[data-tpa-lp-thumbs-prev]');
  var thumbsNext = root.querySelector('[data-tpa-lp-thumbs-next]');

  function updateThumbArrows(){
    if (!thumbsScroll || !thumbsPrev || !thumbsNext) return;
    var sl = thumbsScroll.scrollLeft;
    var maxScroll = thumbsScroll.scrollWidth - thumbsScroll.clientWidth;
    thumbsPrev.disabled = sl <= 2;
    thumbsNext.disabled = sl >= maxScroll - 2;
  }

  if (thumbsScroll && thumbsPrev && thumbsNext){
    thumbsPrev.addEventListener('click', function(){
      thumbsScroll.scrollBy({ left: -200, behavior: 'smooth' });
    });
    thumbsNext.addEventListener('click', function(){
      thumbsScroll.scrollBy({ left: 200, behavior: 'smooth' });
    });
    thumbsScroll.addEventListener('scroll', updateThumbArrows);
    updateThumbArrows();
  }

  function openLightbox(){
    if (!lightbox || !lightboxMedia || !stageMedia) return;
    lightboxMedia.innerHTML = stageMedia.innerHTML;
    lightbox.removeAttribute('hidden');
    lightbox.setAttribute('aria-hidden', 'false');
    document.documentElement.style.overflow = 'hidden';
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox(){
    if (!lightbox) return;
    lightbox.setAttribute('hidden', '');
    lightbox.setAttribute('aria-hidden', 'true');
    document.documentElement.style.overflow = '';
    document.body.style.overflow = '';
  }

  if (stage){
    var touchStartX = 0;
    var touchStartY = 0;
    var touchEndX = 0;
    var touchMoved = false;

    var suppressStageClick = false;

    stage.addEventListener('click', function(){
      if (suppressStageClick) {
        suppressStageClick = false;
        return;
      }
      openLightbox();
    });

    stage.addEventListener('keydown', function(e){
      if (e.key === 'Enter' || e.key === ' '){
        e.preventDefault();
        openLightbox();
      }
      if (e.key === 'ArrowLeft' && thumbs.length > 1){
        e.preventDefault();
        swapToIndex(getActiveIndex() - 1);
      }
      if (e.key === 'ArrowRight' && thumbs.length > 1){
        e.preventDefault();
        swapToIndex(getActiveIndex() + 1);
      }
    });

    stage.addEventListener('touchstart', function(e){
      if (!e.touches || !e.touches.length) return;
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
      touchEndX = touchStartX;
      touchMoved = false;
    }, { passive: true });

    stage.addEventListener('touchmove', function(e){
      if (!e.touches || !e.touches.length) return;
      touchEndX = e.touches[0].clientX;
      var currentY = e.touches[0].clientY;
      if (Math.abs(touchEndX - touchStartX) > 10 || Math.abs(currentY - touchStartY) > 10){
        touchMoved = true;
      }
    }, { passive: true });

    stage.addEventListener('touchend', function(){
      var dx = touchEndX - touchStartX;
      var absDx = Math.abs(dx);

      if (absDx > 40 && thumbs.length > 1){
        suppressStageClick = true;
        var currentIndex = getActiveIndex();
        if (dx < 0){
          swapToIndex(currentIndex + 1);
        } else {
          swapToIndex(currentIndex - 1);
        }
        return;
      }

      if (!touchMoved){
        openLightbox();
      }
    }, { passive: true });
  }

  if (lightboxPrev){
    lightboxPrev.addEventListener('click', function(){
      swapToIndex(getActiveIndex() - 1);
    });
  }

  if (lightboxNext){
    lightboxNext.addEventListener('click', function(){
      swapToIndex(getActiveIndex() + 1);
    });
  }

  if (lightboxCloseBtns.length){
    lightboxCloseBtns.forEach(function(btn){
      btn.addEventListener('click', closeLightbox);
    });
  }

  document.addEventListener('keydown', function(e){
    if (!lightbox || lightbox.hasAttribute('hidden')) return;

    if (e.key === 'Escape'){
      closeLightbox();
    }

    if (e.key === 'ArrowLeft' && thumbs.length > 1){
      swapToIndex(getActiveIndex() - 1);
    }

    if (e.key === 'ArrowRight' && thumbs.length > 1){
      swapToIndex(getActiveIndex() + 1);
    }
  });

  if (lightbox){
    var lbTouchStartX = 0;
    var lbTouchEndX = 0;

    lightbox.addEventListener('touchstart', function(e){
      if (!e.touches || !e.touches.length) return;
      lbTouchStartX = e.touches[0].clientX;
      lbTouchEndX = lbTouchStartX;
    }, { passive: true });

    lightbox.addEventListener('touchmove', function(e){
      if (!e.touches || !e.touches.length) return;
      lbTouchEndX = e.touches[0].clientX;
    }, { passive: true });

    lightbox.addEventListener('touchend', function(){
      var dx = lbTouchEndX - lbTouchStartX;
      if (Math.abs(dx) > 40 && thumbs.length > 1){
        if (dx < 0){
          swapToIndex(getActiveIndex() + 1);
        } else {
          swapToIndex(getActiveIndex() - 1);
        }
      }
    }, { passive: true });
  }

  /* ── Scroll-triggered reveals (guarantees + reviews) ── */
  var revealEls = root.querySelectorAll('[data-tpa-lp-reveal]');
  if (revealEls.length && 'IntersectionObserver' in window){
    var revealObs = new IntersectionObserver(function(entries){
      entries.forEach(function(entry){
        if (entry.isIntersecting){
          var siblings = entry.target.parentElement.querySelectorAll('[data-tpa-lp-reveal]');
          var idx = Array.prototype.indexOf.call(siblings, entry.target);
          setTimeout(function(){
            entry.target.classList.add('is-revealed');
          }, idx * 100);
          revealObs.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12 });
    revealEls.forEach(function(el){ revealObs.observe(el); });
  } else {
    revealEls.forEach(function(el){ el.classList.add('is-revealed'); });
  }

  /* ── Announcement bar rotation ── */
  var announceText = document.querySelector('[data-tpa-lp-announce-text]');
  if (announceText){
    var messages = [
      {{ section.settings.announce_text | json }},
      {{ section.settings.announce_text_2 | json }},
      {{ section.settings.announce_text_3 | json }}
    ].filter(function(m){ return m && m.length > 0; });

    if (messages.length > 1){
      var msgIdx = 0;
      setInterval(function(){
        msgIdx = (msgIdx + 1) % messages.length;
        announceText.style.opacity = '0';
        announceText.style.transform = 'translateY(-4px)';
        setTimeout(function(){
          announceText.textContent = messages[msgIdx];
          announceText.style.opacity = '1';
          announceText.style.transform = 'translateY(0)';
        }, 250);
      }, 4000);
      announceText.style.transition = 'opacity 0.25s ease, transform 0.25s ease';
    }
  }

  /* ── Activity indicator rotation ── */
  var activityText = root.querySelector('[data-tpa-lp-activity-text]');
  if (activityText){
    var activities = [
      {{ section.settings.activity_text | json }},
      {{ section.settings.activity_text_2 | json }},
      {{ section.settings.activity_text_3 | json }}
    ].filter(function(m){ return m && m.length > 0; });

    if (activities.length > 1){
      var actIdx = 0;
      setInterval(function(){
        actIdx = (actIdx + 1) % activities.length;
        activityText.style.opacity = '0';
        setTimeout(function(){
          activityText.textContent = activities[actIdx];
          activityText.style.opacity = '1';
        }, 200);
      }, 5000);
      activityText.style.transition = 'opacity 0.2s ease';
    }
  }

  /* ── Smooth scroll for anchor links ── */
  root.querySelectorAll('a[href^="#tpa-lp"]').forEach(function(link){
    link.addEventListener('click', function(e){
      var target = document.querySelector(link.getAttribute('href'));
      if (target){
        e.preventDefault();
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  /* ── Shipping estimator ── */
  var shipPostcode = root.querySelector('[data-tpa-lp-ship-postcode]');
  var shipCheckBtn = root.querySelector('[data-tpa-lp-ship-check]');
  var shipResult = root.querySelector('[data-tpa-lp-ship-result]');
  var shipBusy = false;

  if (shipPostcode && shipCheckBtn && shipResult){
    /* Allow only numeric input */
    shipPostcode.addEventListener('input', function(){
      this.value = this.value.replace(/[^0-9]/g, '').slice(0, 4);
    });

    /* Trigger on Enter key */
    shipPostcode.addEventListener('keydown', function(e){
      if (e.key === 'Enter'){
        e.preventDefault();
        shipCheckBtn.click();
      }
    });

    /* Load saved postcode */
    try {
      var savedPostcode = localStorage.getItem('tpa_ship_postcode');
      if (savedPostcode && /^\d{4}$/.test(savedPostcode)){
        shipPostcode.value = savedPostcode;
      }
    } catch(e){}

    shipCheckBtn.addEventListener('click', function(){
      if (shipBusy) return;

      var postcode = shipPostcode.value.trim();
      if (!/^\d{4}$/.test(postcode)){
        shipResult.hidden = false;
        shipResult.innerHTML = '<div class="tpa-lp__ship-est-error">Please enter a valid 4-digit Australian postcode.</div>';
        return;
      }

      /* Save postcode for repeat visits */
      try { localStorage.setItem('tpa_ship_postcode', postcode); } catch(e){}

      shipBusy = true;
      shipCheckBtn.disabled = true;
      shipResult.hidden = false;
      shipResult.innerHTML = '<div class="tpa-lp__ship-est-loading"><div class="tpa-lp__ship-est-spinner"></div><span>Calculating shipping rates...</span></div>';

      var currentVariantId = variantInput ? variantInput.value : {{ v.id | json }};
      var currentQty = qty ? parseInt(qty.value || '1', 10) : 1;
      var savedCart = null;

      /* Step 1: Save the current cart */
      fetch('/cart.js', { credentials: 'same-origin' })
        .then(function(r){ return r.json(); })
        .then(function(cart){
          savedCart = cart.items.map(function(item){
            return { id: item.variant_id, quantity: item.quantity };
          });

          /* Step 2: Clear cart and add only this product */
          return fetch('/cart/clear.js', {
            method: 'POST',
            credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json' }
          });
        })
        .then(function(){
          return fetch('/cart/add.js', {
            method: 'POST',
            credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: parseInt(currentVariantId, 10), quantity: currentQty })
          });
        })
        .then(function(r){
          if (!r.ok) throw new Error('Could not add product to cart for rate calculation.');
          return r.json();
        })
        .then(function(){
          /* Step 3: Poll for shipping rates */
          return pollForRates(postcode);
        })
        .then(function(rates){
          renderRates(rates);
        })
        .catch(function(err){
          shipResult.innerHTML = '<div class="tpa-lp__ship-est-fallback">Shipping will be calculated at checkout.</div>';
        })
        .then(function(){
          /* Step 4: Always restore the original cart */
          return restoreCart(savedCart);
        })
        .then(function(){
          shipBusy = false;
          shipCheckBtn.disabled = false;
        });
    });
  }

  function postcodeToState(pc){
    var code = parseInt(pc, 10);
    if (code >= 800 && code <= 999)   return 'Northern Territory';
    if (code >= 200 && code <= 299)   return 'Australian Capital Territory';
    if (code >= 2600 && code <= 2618) return 'Australian Capital Territory';
    if (code >= 2900 && code <= 2920) return 'Australian Capital Territory';
    if (code >= 1000 && code <= 2599) return 'New South Wales';
    if (code >= 2619 && code <= 2899) return 'New South Wales';
    if (code >= 2921 && code <= 2999) return 'New South Wales';
    if (code >= 3000 && code <= 3999) return 'Victoria';
    if (code >= 4000 && code <= 4999) return 'Queensland';
    if (code >= 5000 && code <= 5999) return 'South Australia';
    if (code >= 6000 && code <= 6797) return 'Western Australia';
    if (code >= 6800 && code <= 6999) return 'Western Australia';
    if (code >= 7000 && code <= 7999) return 'Tasmania';
    return '';
  }

  function pollForRates(postcode){
    var maxAttempts = 12;
    var attempt = 0;
    var baseDelay = 1000;

    return new Promise(function(resolve, reject){
      function tryFetch(){
        attempt++;
        var province = postcodeToState(postcode);
        var url = '/cart/shipping_rates.json?shipping_address[zip]=' + encodeURIComponent(postcode)
          + '&shipping_address[country]=Australia&shipping_address[province]=' + encodeURIComponent(province);

        fetch(url, { credentials: 'same-origin' })
          .then(function(r){
            if (r.ok) return r.json();
            if (r.status === 422 && attempt < maxAttempts){
              /* Shopify is still calculating — wait and retry */
              var delay = Math.min(baseDelay * Math.pow(1.3, attempt - 1), 5000);
              setTimeout(tryFetch, delay);
              return null;
            }
            throw new Error('Rate lookup failed (status ' + r.status + ')');
          })
          .then(function(data){
            if (data === null) return; /* polling continues */
            if (data && data.shipping_rates){
              resolve(data.shipping_rates);
            } else {
              reject(new Error('No rates returned'));
            }
          })
          .catch(function(err){
            if (attempt < maxAttempts){
              var delay = Math.min(baseDelay * Math.pow(1.3, attempt - 1), 5000);
              setTimeout(tryFetch, delay);
            } else {
              reject(err);
            }
          });
      }
      tryFetch();
    });
  }

  function renderRates(rates){
    if (!shipResult) return;
    if (!rates || rates.length === 0){
      shipResult.innerHTML = '<div class="tpa-lp__ship-est-fallback">No shipping options available for this postcode.</div>';
      return;
    }

    var truckSvg = '<svg class="tpa-lp__ship-rate-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>';
    var checkSvg = '<svg class="tpa-lp__ship-rate-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';

    var html = '<div class="tpa-lp__ship-rates-list">';
    rates.forEach(function(rate){
      var priceNum = parseFloat(rate.price);
      var isFree = priceNum === 0;
      var priceDisplay = isFree ? 'FREE' : '$' + priceNum.toFixed(2);
      var priceClass = 'tpa-lp__ship-rate-price' + (isFree ? ' tpa-lp__ship-rate-price--free' : '');
      var rowClass = 'tpa-lp__ship-rate' + (isFree ? ' tpa-lp__ship-rate--free' : '');
      var icon = isFree ? checkSvg : truckSvg;

      html += '<div class="' + rowClass + '">'
        + '<div class="tpa-lp__ship-rate-left">'
        + icon
        + '<span class="tpa-lp__ship-rate-name">' + rate.name + '</span>'
        + '</div>'
        + '<span class="' + priceClass + '">' + priceDisplay + '</span>'
        + '</div>';
    });
    html += '</div>';
    shipResult.innerHTML = html;
  }

  function restoreCart(savedItems){
    return fetch('/cart/clear.js', {
      method: 'POST',
      credentials: 'same-origin',
      headers: { 'Content-Type': 'application/json' }
    }).then(function(){
      if (!savedItems || savedItems.length === 0) return;
      return fetch('/cart/add.js', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: savedItems })
      });
    }).catch(function(){
      /* Cart restore failed silently — user's cart may need a page refresh */
    });
  }

  /* ── Final CTA scroll-to-top ── */
  var finalBtn = root.querySelector('.tpa-lp__final-btn');
  if (finalBtn){
    finalBtn.addEventListener('click', function(e){
      e.preventDefault();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }

  /* ── Recently Viewed Products ── */
  var rvSection = root.querySelector('[data-tpa-lp-recently-viewed]');
  var rvRail = root.querySelector('[data-tpa-lp-rv-rail]');

  if (rvSection && rvRail){
    var RV_KEY = 'tpa_recently_viewed';
    var MAX_RV = 8;
    var currentHandle = {{ product.handle | json }};
    var currentProduct = {
      handle: currentHandle,
      title: {{ product.title | json }},
      url: {{ product.url | json }},
      price: {{ v.price | money | json }},
      image: {{ product.featured_image | image_url: width: 400 | json }}
    };

    /* Save current product */
    try {
      var stored = JSON.parse(localStorage.getItem(RV_KEY) || '[]');
      stored = stored.filter(function(p){ return p.handle !== currentHandle; });
      stored.unshift(currentProduct);
      if (stored.length > MAX_RV) stored = stored.slice(0, MAX_RV);
      localStorage.setItem(RV_KEY, JSON.stringify(stored));

      /* Render recently viewed (exclude current product) */
      var toShow = stored.filter(function(p){ return p.handle !== currentHandle; });
      if (toShow.length > 0){
        var html = '';
        toShow.forEach(function(p){
          html += '<a class="tpa-lp__rv-card" href="' + p.url + '">';
          if (p.image){
            html += '<img class="tpa-lp__rv-img" src="' + p.image + '" alt="' + p.title.replace(/"/g, '&quot;') + '" loading="lazy" width="200" height="200">';
          }
          html += '<div class="tpa-lp__rv-info">';
          html += '<div class="tpa-lp__rv-title">' + p.title + '</div>';
          html += '<div class="tpa-lp__rv-price">' + p.price + '</div>';
          html += '</div></a>';
        });
        rvRail.innerHTML = html;
        rvSection.hidden = false;
      }
    } catch(e){}
  }
})();
</script>

