{% comment %} 
  Section: TPA Landing Product Page
  Purpose: High-conversion product page designed for cold traffic from Google Ads.
  Optimized for trust, urgency, and premium authority.
  Uses TPA design system: dark navy gradients, #1D5BFF accent, 950 weights, 18px radii.

  Updated changes:
  - Removed parts compatibility checker
  - Removed free shipping threshold tracker
  - Removed what's in the box section
  - Added clear product description section
  - Moved product description above guarantee section
  - Restored native Shopify add-to-cart behaviour
  - Added variant ID syncing for multi-variant products
  - Improved desktop and mobile responsiveness
  - Optimized for mobile-first UX
{% endcomment %}

{% assign sid = section.id %}
{% assign is_appliance = false %}
{% if product.tags contains 'Appliance' %}
  {% assign is_appliance = true %}
{% endif %}
{% assign is_part = false %}
{% if product.tags contains 'Part' %}
  {% assign is_part = true %}
{% endif %}
{% if is_appliance == false and is_part == false %}
  {% assign is_part = true %}
{% endif %}
{% assign v = product.selected_or_first_available_variant %}
{% assign price = v.price %}
{% assign compare = v.compare_at_price %}

{%- comment -%} ══════════════════════════════════════════
  1. URGENCY ANNOUNCEMENT BAR
{%- endcomment -%}
<div class="tpa-lp__announce tpa-lp__announce--{{ sid }}" data-tpa-lp-announce>
  <div class="tpa-lp__announce-inner">
    <span class="tpa-lp__announce-dot" aria-hidden="true"></span>
    <span class="tpa-lp__announce-text" data-tpa-lp-announce-text>{{ section.settings.announce_text }}</span>
  </div>
</div>

{%- comment -%} ══════════════════════════════════════════
  2. MAIN PRODUCT SECTION
{%- endcomment -%}
<section id="tpa-lp-top-{{ sid }}" class="tpa-lp tpa-lp--{{ sid }} color-{{ section.settings.color_scheme }}">
  <div class="tpa-lp__inner">

    {%- comment -%} ── PRODUCT HERO GRID ── {%- endcomment -%}
    <div class="tpa-lp__hero">

      {%- comment -%} LEFT: MEDIA GALLERY {%- endcomment -%}
      <div class="tpa-lp__gallery" data-tpa-lp-gallery>
        {% assign featured = product.featured_media %}
        {% if featured %}
          <div
            class="tpa-lp__stage"
            data-tpa-lp-stage
            data-tpa-lp-zoom
            data-active-media-id="{{ featured.id }}"
            tabindex="0"
            role="button"
            aria-label="Open product media in full screen"
          >
            <div class="tpa-lp__stage-media" data-tpa-lp-stage-media>
              {% render 'tpa-pdp-media', media: featured, index: 0 %}
            </div>

            {% if section.settings.media_badge_enable %}
              <div class="tpa-lp__media-badge">
                <span class="tpa-lp__media-badge-dot" aria-hidden="true"></span>
                <span>{{ section.settings.media_badge_text }}</span>
              </div>
            {% endif %}

            {% if compare > price %}
              <div class="tpa-lp__sale-flag" aria-label="On sale">
                <span>SAVE {{ compare | minus: price | money }}</span>
              </div>
            {% endif %}

            {% if product.media.size > 1 %}
              <button class="tpa-lp__stage-nav tpa-lp__stage-nav--prev" type="button" data-tpa-lp-stage-prev aria-label="Previous image">‹</button>
              <button class="tpa-lp__stage-nav tpa-lp__stage-nav--next" type="button" data-tpa-lp-stage-next aria-label="Next image">›</button>
            {% endif %}
          </div>

          <div class="tpa-lp__media-templates" hidden>
            {% for media in product.media %}
              <template data-tpa-lp-template="{{ media.id }}">
                {% render 'tpa-pdp-media', media: media, index: forloop.index0 %}
              </template>
            {% endfor %}
          </div>

          <div class="tpa-lp__lightbox" data-tpa-lp-lightbox hidden aria-hidden="true">
            <div class="tpa-lp__lightbox-backdrop" data-tpa-lp-lightbox-close></div>

            <div class="tpa-lp__lightbox-dialog" role="dialog" aria-modal="true" aria-label="Product media viewer">
              <button class="tpa-lp__lightbox-close" type="button" data-tpa-lp-lightbox-close aria-label="Close full screen media">×</button>

              {% if product.media.size > 1 %}
                <button class="tpa-lp__lightbox-nav tpa-lp__lightbox-nav--prev" type="button" data-tpa-lp-lightbox-prev aria-label="Previous image">‹</button>
                <button class="tpa-lp__lightbox-nav tpa-lp__lightbox-nav--next" type="button" data-tpa-lp-lightbox-next aria-label="Next image">›</button>
              {% endif %}

              <div class="tpa-lp__lightbox-media" data-tpa-lp-lightbox-media></div>
            </div>
          </div>
        {% endif %}

        {% assign media_count = product.media.size %}
        {% if media_count > 1 %}
          <div class="tpa-lp__thumbs-wrap" data-tpa-lp-thumbs-wrap>
            <button class="tpa-lp__thumbs-arrow tpa-lp__thumbs-arrow--prev" type="button" data-tpa-lp-thumbs-prev aria-label="Scroll thumbnails left">‹</button>
            <div class="tpa-lp__thumbs" aria-label="Product media" data-tpa-lp-thumbs-scroll>
              {% for media in product.media %}
                <button
                  class="tpa-lp__thumb{% if media.id == featured.id %} is-active{% endif %}"
                  type="button"
                  data-tpa-lp-thumb
                  data-media-id="{{ media.id }}"
                  aria-label="View media {{ forloop.index }}"
                >
                  {% if media.preview_image %}
                    <img
                      src="{{ media.preview_image | image_url: width: 220 }}"
                      alt="{{ media.preview_image.alt | default: product.title | escape }}"
                      loading="lazy"
                      width="84"
                      height="84"
                    >
                  {% endif %}
                </button>
              {% endfor %}
            </div>
            <button class="tpa-lp__thumbs-arrow tpa-lp__thumbs-arrow--next" type="button" data-tpa-lp-thumbs-next aria-label="Scroll thumbnails right">›</button>
          </div>
        {% endif %}
      </div>

      {%- comment -%} RIGHT: PRODUCT INFO + BUY BOX {%- endcomment -%}
      <div class="tpa-lp__buy">

        {%- comment -%} Live activity indicator {%- endcomment -%}
        <div class="tpa-lp__activity" data-tpa-lp-activity>
          <span class="tpa-lp__activity-dot" aria-hidden="true"></span>
          <span data-tpa-lp-activity-text>{{ section.settings.activity_text }}</span>
        </div>

        <h1 class="tpa-lp__title">{{ product.title }}</h1>

        {% assign subheadline = product.metafields.tpa.subheadline.value %}
        {% if subheadline == blank %}
          {% if is_part %}
            {% assign subheadline = section.settings.part_subheadline_fallback %}
          {% else %}
            {% assign subheadline = section.settings.appliance_subheadline_fallback %}
          {% endif %}
        {% endif %}
        {% if subheadline != blank %}
          <div class="tpa-lp__subheadline">{{ subheadline }}</div>
        {% endif %}

        {%- comment -%} Rating + review count {%- endcomment -%}
        <div class="tpa-lp__rating">
          <div class="tpa-lp__stars" aria-label="{{ section.settings.rating_stars }} out of 5 stars">
            {% assign star_count = section.settings.rating_stars | plus: 0 %}
            {% for i in (1..5) %}
              <span class="tpa-lp__star{% if i <= star_count %} is-on{% endif %}" aria-hidden="true">★</span>
            {% endfor %}
          </div>
          <span class="tpa-lp__rating-score">{{ section.settings.rating_stars }}/5</span>
          <a class="tpa-lp__rating-link" href="#tpa-lp-reviews-{{ sid }}">{{ section.settings.rating_count }} verified reviews</a>
        </div>

        {%- comment -%} Price block {%- endcomment -%}
        <div class="tpa-lp__price-block" data-tpa-lp-price>
          {% if is_appliance and product.metafields.tpa.free_metro_shipping %}
            <div class="tpa-lp__price-offer">
              <span class="tpa-lp__price-offer-dot" aria-hidden="true"></span>
              <span>FREE SHIPPING TO METRO AREAS</span>
            </div>
          {% elsif is_part and product.metafields.tpa.free_shipping %}
            <div class="tpa-lp__price-offer">
              <span class="tpa-lp__price-offer-dot" aria-hidden="true"></span>
              <span>FREE SHIPPING</span>
            </div>
          {% endif %}

          <div class="tpa-lp__price-row">
            <div class="tpa-lp__price">{{ price | money }}</div>
            {% if compare > price %}
              <div class="tpa-lp__compare">{{ compare | money }}</div>
              <div class="tpa-lp__save-pill">
                Save {{ compare | minus: price | money }}
              </div>
            {% endif %}
          </div>
          <div class="tpa-lp__price-note">{{ section.settings.price_note }}</div>
          {%- comment -%} App blocks (e.g. Afterpay onsite messaging) {%- endcomment -%}
          {% for block in section.blocks %}
            {% if block.type == '@app' %}
              <div class="tpa-lp__app-block" {{ block.shopify_attributes }}>
                {% render block %}
              </div>
            {% endif %}
          {% endfor %}
        </div>

        {%- comment -%} Shipping estimator {%- endcomment -%}
        <div class="tpa-lp__ship-est" data-tpa-lp-ship-est>
          <div class="tpa-lp__ship-est-header">
            <svg class="tpa-lp__ship-est-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            <span class="tpa-lp__ship-est-title">Estimate Shipping</span>
          </div>
          <div class="tpa-lp__ship-est-form">
            <input
              class="tpa-lp__ship-est-input"
              type="text"
              inputmode="numeric"
              pattern="[0-9]*"
              maxlength="4"
              placeholder="Enter postcode"
              aria-label="Australian postcode"
              data-tpa-lp-ship-postcode
            >
            <button class="tpa-lp__ship-est-btn" type="button" data-tpa-lp-ship-check>
              Check
            </button>
          </div>
          <div class="tpa-lp__ship-est-result" data-tpa-lp-ship-result hidden></div>
        </div>

        {%- comment -%} Stock urgency {%- endcomment -%}
        {% if section.settings.stock_urgency_enable %}
          <div class="tpa-lp__stock" data-tpa-lp-stock>
            <span class="tpa-lp__stock-dot" aria-hidden="true"></span>
            <span class="tpa-lp__stock-text">{{ section.settings.stock_text }}</span>
          </div>
        {% endif %}

        {%- comment -%} ── PRODUCT FORM ── {%- endcomment -%}
        {% form 'product', product, class: 'tpa-lp__form', data-tpa-lp-form: '' %}
          <input type="hidden" name="id" value="{{ v.id }}" data-tpa-lp-variant-id>

          {% if product.has_only_default_variant == false %}
            <div class="tpa-lp__variants">
              {% for option in product.options_with_values %}
                <div class="tpa-lp__opt">
                  <div class="tpa-lp__opt-label">{{ option.name }}</div>
                  <div class="tpa-lp__opt-values">
                    {% for value in option.values %}
                      <label class="tpa-lp__chip">
                        <input
                          type="radio"
                          name="options[{{ option.name | escape }}]"
                          value="{{ value | escape }}"
                          {% if option.selected_value == value %}checked{% endif %}
                        >
                        <span>{{ value }}</span>
                      </label>
                    {% endfor %}
                  </div>
                </div>
              {% endfor %}
            </div>
          {% endif %}

          {%- comment -%} Appliance: Specs grid {%- endcomment -%}
          {% if is_appliance %}
            <div class="tpa-lp__module tpa-lp__specs-module">
              <div class="tpa-lp__module-header">
                <div class="tpa-lp__module-icon" aria-hidden="true">📋</div>
                <div class="tpa-lp__module-title">{{ section.settings.specs_title }}</div>
              </div>

              <div class="tpa-lp__specs-grid">
                <div class="tpa-lp__spec">
                  <div class="tpa-lp__spec-icon" aria-hidden="true">🛡️</div>
                  <div class="tpa-lp__spec-k">{{ section.settings.specs_warranty_label }}</div>
                  <div class="tpa-lp__spec-v">
                    {% assign warranty = product.metafields.tpa.warranty.value %}
                    {{ warranty | default: section.settings.specs_warranty_fallback }}
                  </div>
                </div>
                <div class="tpa-lp__spec">
                  <div class="tpa-lp__spec-icon" aria-hidden="true">🚚</div>
                  <div class="tpa-lp__spec-k">{{ section.settings.specs_shipping_label }}</div>
                  <div class="tpa-lp__spec-v">
                    {% assign ship = product.metafields.tpa.shipping_notes.value %}
                    {{ ship | default: section.settings.specs_shipping_fallback }}
                  </div>
                </div>
                <div class="tpa-lp__spec">
                  <div class="tpa-lp__spec-icon" aria-hidden="true">⚙️</div>
                  <div class="tpa-lp__spec-k">{{ section.settings.specs_setup_label }}</div>
                  <div class="tpa-lp__spec-v">
                    {% assign setup = product.metafields.tpa.install_notes.value %}
                    {{ setup | default: section.settings.specs_setup_fallback }}
                  </div>
                </div>
                <div class="tpa-lp__spec tpa-lp__spec--full">
                  <div class="tpa-lp__spec-icon" aria-hidden="true">📊</div>
                  <div class="tpa-lp__spec-k">{{ section.settings.specs_key_label }}</div>
                  <div class="tpa-lp__spec-v">
                    {% assign specs = product.metafields.tpa.specs.value %}
                    {{ specs | default: section.settings.specs_key_fallback }}
                  </div>
                </div>
              </div>
            </div>
          {% endif %}

          {%- comment -%} Quantity + ATC {%- endcomment -%}
          <div class="tpa-lp__buy-row">
            <div class="tpa-lp__qty" data-tpa-lp-qty>
              <button class="tpa-lp__qty-btn" type="button" data-tpa-lp-qty-dec aria-label="Decrease quantity">−</button>
              <input class="tpa-lp__qty-input" type="number" name="quantity" value="1" min="1" inputmode="numeric" data-tpa-lp-qty-input>
              <button class="tpa-lp__qty-btn" type="button" data-tpa-lp-qty-inc aria-label="Increase quantity">+</button>
            </div>

            <button
              class="tpa-lp__atc"
              type="submit"
              name="add"
              {% unless v.available %}disabled{% endunless %}
              data-tpa-lp-atc
            >
              <span class="tpa-lp__atc-shimmer" aria-hidden="true"></span>
              <span class="tpa-lp__atc-default">
                <span aria-hidden="true">🛒</span>
                <span>{% if v.available %}{{ section.settings.atc_label }}{% else %}{{ section.settings.sold_out_label }}{% endif %}</span>
              </span>
            </button>
          </div>

          {%- comment -%} Accelerated checkout (Shop Pay, Apple Pay, Google Pay) {%- endcomment -%}
          {% if v.available %}
            <div class="tpa-lp__dynamic-checkout">
              {{ form | payment_button }}
            </div>
          {% endif %}

          {%- comment -%} Secure checkout badge {%- endcomment -%}
          <div class="tpa-lp__pay-badges">
            <div class="tpa-lp__pay-badges-row">
              <svg class="tpa-lp__pay-lock" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              <span class="tpa-lp__pay-label">Secure Checkout</span>
            </div>
          </div>

          {%- comment -%} Trust strip (inline, below ATC) {%- endcomment -%}
          <div class="tpa-lp__trust-strip">
            {% if is_part %}
              <div class="tpa-lp__trust-item"><span class="tpa-lp__trust-check" aria-hidden="true">✓</span> {{ section.settings.trust_part_1 }}</div>
              <div class="tpa-lp__trust-item"><span class="tpa-lp__trust-check" aria-hidden="true">✓</span> {{ section.settings.trust_part_2 }}</div>
              <div class="tpa-lp__trust-item"><span class="tpa-lp__trust-check" aria-hidden="true">✓</span> {{ section.settings.trust_part_3 }}</div>
              <div class="tpa-lp__trust-item"><span class="tpa-lp__trust-check" aria-hidden="true">✓</span> {{ section.settings.trust_part_4 }}</div>
            {% else %}
              <div class="tpa-lp__trust-item"><span class="tpa-lp__trust-check" aria-hidden="true">✓</span> {{ section.settings.trust_app_1 }}</div>
              <div class="tpa-lp__trust-item"><span class="tpa-lp__trust-check" aria-hidden="true">✓</span> {{ section.settings.trust_app_2 }}</div>
              <div class="tpa-lp__trust-item"><span class="tpa-lp__trust-check" aria-hidden="true">✓</span> {{ section.settings.trust_app_3 }}</div>
              <div class="tpa-lp__trust-item"><span class="tpa-lp__trust-check" aria-hidden="true">✓</span> {{ section.settings.trust_app_4 }}</div>
            {% endif %}
          </div>


          {%- comment -%} Sticky mobile bar {%- endcomment -%}
          <div class="tpa-lp__sticky" data-tpa-lp-sticky>
            <div class="tpa-lp__sticky-left">
              <div class="tpa-lp__sticky-title">{{ product.title | truncate: 36 }}</div>
              <div class="tpa-lp__sticky-price">
                {{ price | money }}
                {% if compare > price %}
                  <span class="tpa-lp__sticky-save">Save {{ compare | minus: price | money }}</span>
                {% endif %}
              </div>
            </div>
            <button class="tpa-lp__sticky-atc" type="submit" name="add" {% unless v.available %}disabled{% endunless %}>
              <span aria-hidden="true">🛒</span> {{ section.settings.atc_label }}
            </button>
          </div>
        {% endform %}
      </div>
    </div>

    {%- comment -%} ══════════════════════════════════════════
      3. SOCIAL PROOF COUNTER BAR
    {%- endcomment -%}
    <div class="tpa-lp__proof-bar" data-tpa-lp-proof>
      <div class="tpa-lp__proof-item">
        <div class="tpa-lp__proof-num" data-tpa-lp-countup="{{ section.settings.proof_1_num }}">{{ section.settings.proof_1_num }}</div>
        <div class="tpa-lp__proof-label">{{ section.settings.proof_1_label }}</div>
      </div>
      <div class="tpa-lp__proof-divider" aria-hidden="true"></div>
      <div class="tpa-lp__proof-item">
        <div class="tpa-lp__proof-num">{{ section.settings.proof_2_num }}</div>
        <div class="tpa-lp__proof-label">{{ section.settings.proof_2_label }}</div>
      </div>
      <div class="tpa-lp__proof-divider" aria-hidden="true"></div>
      <div class="tpa-lp__proof-item">
        <div class="tpa-lp__proof-num">{{ section.settings.proof_3_num }}</div>
        <div class="tpa-lp__proof-label">{{ section.settings.proof_3_label }}</div>
      </div>
      <div class="tpa-lp__proof-divider" aria-hidden="true"></div>
      <div class="tpa-lp__proof-item">
        <div class="tpa-lp__proof-num">{{ section.settings.proof_4_num }}</div>
        <div class="tpa-lp__proof-label">{{ section.settings.proof_4_label }}</div>
      </div>
    </div>

    {%- comment -%} ══════════════════════════════════════════
      4. PRODUCT DESCRIPTION
    {%- endcomment -%}
    <div class="tpa-lp__description-section" data-tpa-lp-section>
      <div class="tpa-lp__description-card">
        <div class="tpa-lp__description-header">
          <span class="tpa-lp__detail-icon" aria-hidden="true">📝</span>
          <h2 class="tpa-lp__description-title">Product Description</h2>
        </div>
        <div class="tpa-lp__description-body rte">
          {% if product.description != blank %}
            {{ product.description }}
          {% else %}
            <p>Product description coming soon.</p>
          {% endif %}
        </div>
      </div>
    </div>

    {%- comment -%} ══════════════════════════════════════════
      5. RISK REVERSAL GUARANTEE STRIP
    {%- endcomment -%}
    <div class="tpa-lp__guarantees" data-tpa-lp-section>
      <div class="tpa-lp__guarantees-header">
        <div class="tpa-lp__guarantees-pill">ZERO RISK</div>
        <h2 class="tpa-lp__section-title">{{ section.settings.guarantee_title }}</h2>
      </div>
      <div class="tpa-lp__guarantees-grid">
        <div class="tpa-lp__guarantee" data-tpa-lp-reveal>
          <div class="tpa-lp__guarantee-icon" aria-hidden="true">🎯</div>
          <div class="tpa-lp__guarantee-title">{{ section.settings.guarantee_1_title }}</div>
          <div class="tpa-lp__guarantee-desc">{{ section.settings.guarantee_1_desc }}</div>
        </div>
        <div class="tpa-lp__guarantee" data-tpa-lp-reveal>
          <div class="tpa-lp__guarantee-icon" aria-hidden="true">🚚</div>
          <div class="tpa-lp__guarantee-title">{{ section.settings.guarantee_2_title }}</div>
          <div class="tpa-lp__guarantee-desc">{{ section.settings.guarantee_2_desc }}</div>
        </div>
        <div class="tpa-lp__guarantee" data-tpa-lp-reveal>
          <div class="tpa-lp__guarantee-icon" aria-hidden="true">↩️</div>
          <div class="tpa-lp__guarantee-title">{{ section.settings.guarantee_3_title }}</div>
          <div class="tpa-lp__guarantee-desc">{{ section.settings.guarantee_3_desc }}</div>
        </div>
        <div class="tpa-lp__guarantee" data-tpa-lp-reveal>
          <div class="tpa-lp__guarantee-icon" aria-hidden="true">🇦🇺</div>
          <div class="tpa-lp__guarantee-title">{{ section.settings.guarantee_4_title }}</div>
          <div class="tpa-lp__guarantee-desc">{{ section.settings.guarantee_4_desc }}</div>
        </div>
      </div>
    </div>

    {%- comment -%} ══════════════════════════════════════════
      6. BENEFITS
    {%- endcomment -%}
    <div class="tpa-lp__details-grid tpa-lp__details-grid--single" data-tpa-lp-section>
      <div class="tpa-lp__detail-card">
        <div class="tpa-lp__detail-header">
          <span class="tpa-lp__detail-icon" aria-hidden="true">⚡</span>
          <span class="tpa-lp__detail-title">{{ section.settings.benefits_title }}</span>
        </div>
        <div class="tpa-lp__detail-body">
          {% if is_part %}
            <div class="tpa-lp__benefit"><span class="tpa-lp__benefit-check" aria-hidden="true">✓</span> {{ section.settings.benefit_part_1 }}</div>
            <div class="tpa-lp__benefit"><span class="tpa-lp__benefit-check" aria-hidden="true">✓</span> {{ section.settings.benefit_part_2 }}</div>
            <div class="tpa-lp__benefit"><span class="tpa-lp__benefit-check" aria-hidden="true">✓</span> {{ section.settings.benefit_part_3 }}</div>
            <div class="tpa-lp__benefit"><span class="tpa-lp__benefit-check" aria-hidden="true">✓</span> {{ section.settings.benefit_part_4 }}</div>
            <div class="tpa-lp__benefit"><span class="tpa-lp__benefit-check" aria-hidden="true">✓</span> {{ section.settings.benefit_part_5 }}</div>
          {% else %}
            <div class="tpa-lp__benefit"><span class="tpa-lp__benefit-check" aria-hidden="true">✓</span> {{ section.settings.benefit_app_1 }}</div>
            <div class="tpa-lp__benefit"><span class="tpa-lp__benefit-check" aria-hidden="true">✓</span> {{ section.settings.benefit_app_2 }}</div>
