{% comment %} Renders image, video, external video, model, with safe defaults {% endcomment %}

{% if media.media_type == 'image' %}
  <img
    src="{{ media | image_url: width: 1600 }}"
    alt="{{ media.alt | default: product.title | escape }}"
    loading="eager"
    width="1200"
    height="1200"
  >
{% elsif media.media_type == 'video' %}
  {{ media | video_tag: controls: true, autoplay: false, loop: false, muted: false }}
{% elsif media.media_type == 'external_video' %}
  {{ media | external_video_tag }}
{% elsif media.media_type == 'model' %}
  {{ media | model_viewer_tag }}
{% endif %}