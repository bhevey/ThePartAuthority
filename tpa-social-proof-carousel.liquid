      "label": "Subheading",
      "default": "Real customers. Real results. Fast shipping across Australia."
    },
    {
      "type": "color",
      "id": "bg",
      "label": "Section background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "accent",
      "label": "Accent blue",
      "default": "#1D5BFF"
    },
    {
      "type": "header",
      "content": "Stats row"
    },
    {
      "type": "checkbox",
      "id": "stats_enable",
      "label": "Show stats row",
      "default": true
    },
    {
      "type": "text",
      "id": "stat_1_num",
      "label": "Stat 1 number",
      "default": "50,000+"
    },
    {
      "type": "text",
      "id": "stat_1_label",
      "label": "Stat 1 label",
      "default": "Parts sold"
    },
    {
      "type": "text",
      "id": "stat_2_num",
      "label": "Stat 2 number",
      "default": "4.8/5"
    },
    {
      "type": "text",
      "id": "stat_2_label",
      "label": "Stat 2 label",
      "default": "Average rating"
    },
    {
      "type": "text",
      "id": "stat_3_num",
      "label": "Stat 3 number",
      "default": "2 min"
    },
    {
      "type": "text",
      "id": "stat_3_label",
      "label": "Stat 3 label",
      "default": "Typical install time"
    },
    {
      "type": "header",
      "content": "CTA row"
    },
    {
      "type": "checkbox",
      "id": "cta_enable",
      "label": "Show CTAs",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "Primary CTA label",
      "default": "Find Your Part"
    },
    {
      "type": "url",
      "id": "cta_primary_link",
      "label": "Primary CTA link"
    },
    {
      "type": "text",
      "id": "cta_secondary_label",
      "label": "Secondary CTA label",
      "default": "View Best Sellers"
    },
    {
      "type": "url",
      "id": "cta_secondary_link",
      "label": "Secondary CTA link"
    },
    {
      "type": "color",
      "id": "cta_bg",
      "label": "Primary CTA background",
      "default": "#1D5BFF"
    },
    {
      "type": "color",
      "id": "cta_fg",
      "label": "Primary CTA text",
      "default": "#FFFFFF"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 140,
      "step": 4,
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 140,
      "step": 4,
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "range",
          "id": "stars",
          "label": "Stars",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
